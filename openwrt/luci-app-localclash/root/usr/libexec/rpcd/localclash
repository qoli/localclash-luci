start_bootstrap_default() {
	local result rc
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	rm -f "$TASK_STATUS" "$TASK_RESULT"
	: > "$LOG"
	write_task_running "初始化任务正在运行。"
	log_line "默认初始化：已加入后台任务队列"
	(
		result="$("$0" call bootstrap_default_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"初始化任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		printf '{"ok":true,"running":false,"done":true,"exit_code":%s,"result":%s}\n' "$rc" "$result" > "$TASK_STATUS"
	) >/dev/null 2>&1 &
	ok '"started":true,"running":true,"summary":"初始化任务已启动。"'
}

bootstrap_default_run() {
	local tmpdir mihomo_attempt
	log_line "默认初始化：开始路由器默认设置"
	tmpdir="$(mktemp -d /tmp/localclash-default.XXXXXX)" || {
		log_line "默认初始化：临时目录创建失败"
		fail "tmpdir_failed" "无法创建临时默认设置目录。"
		return 1
	}

	if ! core_installed; then
		log_line "默认初始化：localClash 核心缺失，开始初始化"
		if ! bootstrap_core > "$tmpdir/core.json"; then
			cat "$tmpdir/core.json"
			rm -rf "$tmpdir"
			return 1
		fi
	else
		log_line "默认初始化：localClash 核心已安装"
		printf '{"ok":true,"changed":false,"summary":"localClash 核心已安装。"}\n' > "$tmpdir/core.json"
	fi

	if ! base_assets_installed; then
		log_line "默认初始化：基础文件缺失，开始初始化"
		if ! bootstrap_assets > "$tmpdir/assets.json"; then
			cat "$tmpdir/assets.json"
			rm -rf "$tmpdir"
			return 1
		fi
	else
		log_line "默认初始化：基础文件已安装"
	fi

	if mihomo_core_installed; then
		log_line "默认初始化：Mihomo 核心已安装，跳过更新"
	else
		log_line "默认初始化：正在更新 Mihomo 核心"
		mihomo_attempt=1
		while ! run_with_heartbeat "默认初始化：正在更新 Mihomo 核心" "$tmpdir/mihomo.json" call_core component update mihomo --json; do
			if [ "$mihomo_attempt" -ge 3 ]; then
				log_line "默认初始化：Mihomo 核心更新失败，已尝试 $mihomo_attempt 次"
				cat "$tmpdir/mihomo.json"
				rm -rf "$tmpdir"
				return 1
			fi
			mihomo_attempt=$((mihomo_attempt + 1))
			log_line "默认初始化：Mihomo 核心更新失败，正在进行第 $mihomo_attempt 次重试"
			sleep 2
		done
	fi

	if dashboard_installed; then
		log_line "默认初始化：Dashboard 面板文件已安装，跳过更新"
	else
		log_line "默认初始化：正在更新 Dashboard 面板文件"
		if ! run_with_heartbeat "默认初始化：正在更新 Dashboard 面板文件" "$tmpdir/dashboard.json" call_core component update dashboard --json; then
			log_line "默认初始化：Dashboard 面板更新失败"
			cat "$tmpdir/dashboard.json"
			rm -rf "$tmpdir"
			return 1
		fi
	fi

	cat > "$tmpdir/template.json" <<'JSON'
{
  "version": 1,
  "template": "localclash-default",
  "runtime_profile": "router",
  "core": "meta",
  "allow_overwrite_modified": false
}
JSON

	log_line "默认初始化：正在应用 router/meta 默认配置"
	if ! call_core config apply-template --input "$tmpdir/template.json" --json > "$tmpdir/template-result.json"; then
		log_line "默认初始化：默认配置应用失败"
		cat "$tmpdir/template-result.json"
		rm -rf "$tmpdir"
		return 1
	fi

	if ! service_start >/dev/null; then
		rm -rf "$tmpdir"
		log_line "默认初始化：MCP 服务启动失败"
		fail "service_start_failed" "默认配置已应用，但 MCP 服务无法启动。"
		return 1
	fi
	rm -rf "$tmpdir"
	log_line "默认初始化：已完成路由器默认设置"
	ok '"changed":true,"summary":"已应用路由器默认设置。","profile":{"runtime_profile":"router","core":"meta","template":"localclash-default"}'
}

start_runtime_takeover() {
	local result rc
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	rm -f "$TASK_STATUS" "$TASK_RESULT"
	: > "$LOG"
	write_task_running "运行时启动和网络接管任务正在运行。"
	log_line "运行时接管：已加入后台任务队列"
	(
		result="$("$0" call runtime_start_takeover_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"运行时启动和网络接管任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		printf '{"ok":true,"running":false,"done":true,"exit_code":%s,"result":%s}\n' "$rc" "$result" > "$TASK_STATUS"
	) >/dev/null 2>&1 &
	ok '"started":true,"running":true,"summary":"运行时启动和网络接管任务已启动。"'
}

runtime_start_takeover_run() {
	local tmpdir
	log_line "运行时接管：开始"
	tmpdir="$(mktemp -d /tmp/localclash-runtime.XXXXXX)" || {
		log_line "运行时接管：临时目录创建失败"
		fail "tmpdir_failed" "无法创建临时 runtime 任务目录。"
		return 1
	}

	log_line "运行时接管：正在启动运行时"
	if ! run_with_heartbeat "运行时接管：正在启动运行时" "$tmpdir/runtime.json" call_core runtime start --json; then
		log_line "运行时接管：运行时启动失败"
		cat "$tmpdir/runtime.json"
		rm -rf "$tmpdir"
		return 1
	fi

	log_line "运行时接管：正在应用网络接管"
	if ! run_with_heartbeat "运行时接管：正在应用网络接管" "$tmpdir/takeover.json" call_core takeover apply --json; then
		log_line "运行时接管：网络接管应用失败"
		log_line "运行时接管：正在撤销可能残留的网络接管"
		if call_core takeover stop --json > "$tmpdir/takeover-stop.json"; then
			log_line "运行时接管：网络接管撤销完成"
		else
			log_line "运行时接管：网络接管撤销也失败"
		fi
		log_line "运行时接管：网络接管失败后正在停止运行时"
		runtime_stop > "$tmpdir/runtime-stop.json" 2>/dev/null || log_line "运行时接管：失败后停止运行时也失败"
		cat "$tmpdir/takeover.json"
		rm -rf "$tmpdir"
		return 1
	fi

	log_line "运行时接管：已完成"
	printf '{"ok":true,"changed":true,"summary":"运行时已启动，网络接管已应用。","runtime":%s,"takeover":%s}\n' "$(cat "$tmpdir/runtime.json")" "$(cat "$tmpdir/takeover.json")"
	rm -rf "$tmpdir"
}

method="${1:-}"
if [ "$method" = "call" ]; then
	method="${2:-}"
fi

case "$method" in
	list)
		cat <<'JSON'
{
	  "status": {},
	  "subscription_get": {},
	  "subscription_set": { "urls": [] },
  "subscription_setup": { "urls": [] },
  "subscription_setup_async": { "urls": [] },
  "subscription_refresh": {},
  "component_update": { "component": "localclash" },
  "component_update_async": { "component": "localclash" },
  "apply": {},
  "config_render": {},
  "config_reset": {},
  "runtime_start": {},
  "runtime_start_takeover": {},
  "runtime_restart": {},
  "runtime_stop": {},
  "takeover_status": {},
  "takeover_apply": {},
  "takeover_stop": {},
  "reset": {},
  "service_start": {},
  "service_stop": {},
  "service_status": {},
  "service_ensure": {},
  "bootstrap_core": {},
  "bootstrap_core_async": {},
  "bootstrap_assets": {},
  "bootstrap_default": {},
  "task_status": {},
  "bootstrap_task_status": {},
  "mcp_help": {},
  "bootstrap_logs": {}
}
JSON
		;;
	status) status ;;
	subscription_get) subscription_get ;;
	subscription_set) subscription_set ;;
	subscription_setup) with_lock subscription_setup ;;
	subscription_setup_async) start_subscription_setup ;;
	subscription_setup_run) with_lock subscription_setup_run ;;
	subscription_refresh) with_lock call_core subscription refresh --json ;;
	component_update) with_lock component_update ;;
	component_update_async) start_component_update ;;
	component_update_run) component_update_run ;;
	apply) with_lock apply_state ;;
	config_render) with_lock config_render ;;
	config_reset) with_lock config_reset ;;
	runtime_start) runtime_start ;;
	runtime_start_takeover) start_runtime_takeover ;;
	runtime_start_takeover_run) with_lock runtime_start_takeover_run ;;
	runtime_restart) runtime_restart ;;
	runtime_stop) runtime_stop ;;
	takeover_status) call_core takeover status --json ;;
	takeover_apply) call_core takeover apply --json ;;
	takeover_stop) call_core takeover stop --json ;;
	reset) call_core reset --json ;;
	service_status) service_status ;;
	service_ensure) service_ensure ;;
	service_start) service_start ;;
	service_stop) [ -x "$SERVICE" ] && "$SERVICE" stop >/dev/null 2>&1 && "$SERVICE" disable >/dev/null 2>&1; service_status ;;
	bootstrap_core) with_lock bootstrap_core ;;
	bootstrap_core_async) start_bootstrap_core ;;
	bootstrap_core_run) with_lock bootstrap_core ;;
	bootstrap_assets) with_lock bootstrap_assets ;;
	bootstrap_default) start_bootstrap_default ;;
	bootstrap_default_run) with_lock bootstrap_default_run ;;
	task_status) task_status ;;
	bootstrap_task_status) bootstrap_task_status ;;
	mcp_help) mcp_help ;;
	bootstrap_logs) bootstrap_logs ;;
	*) fail "unknown_method" "未知的 localClash rpcd 方法。" ;;
esac

exit 0
