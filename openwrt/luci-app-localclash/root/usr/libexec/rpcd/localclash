service_body() {
	local installed enabled running pid endpoint health_endpoint health_probe health_body healthy last_error
	installed=false
	enabled=false
	running=false
	pid=0
	healthy=false
	last_error=""
	if [ -x "$SERVICE" ]; then
		installed=true
		"$SERVICE" enabled >/dev/null 2>&1 && enabled=true
		if "$SERVICE" running >/dev/null 2>&1; then
			running=true
			pid="$(ps w 2>/dev/null | awk '/[l]ocalclash mcp serve/ { print $1; exit }')"
			[ -n "$pid" ] || pid=0
		fi
	fi
	endpoint="$(mcp_endpoint)"
	health_endpoint="${endpoint%/mcp}/health"
	if [ "$running" = true ]; then
		health_probe="$(mcp_local_health_endpoint)"
		health_body="$(mcp_health_body "$health_probe" 2>/tmp/localclash-mcp-health.err || true)"
		if printf '%s' "$health_body" | grep -q '"status":"ok"'; then
			healthy=true
		else
			last_error="$(cat /tmp/localclash-mcp-health.err 2>/dev/null || true)"
			[ -n "$last_error" ] || last_error="MCP 健康检查未返回 ok。"
		fi
		rm -f /tmp/localclash-mcp-health.err
	fi
	printf '"service":{"name":"localclash-mcp","installed":%s,"enabled":%s,"running":%s,"pid":%s},"mcp":{"endpoint":"%s","health_endpoint":"%s","healthy":%s,"last_error":"%s"}' "$installed" "$enabled" "$running" "$pid" "$(json_escape "$endpoint")" "$(json_escape "$health_endpoint")" "$healthy" "$(json_escape "$last_error")"
}

mcp_health_body() {
	local url
	url="$1"
	if command -v uclient-fetch >/dev/null 2>&1; then
		uclient-fetch -T 2 -q -O - "$url"
	elif command -v wget >/dev/null 2>&1; then
		wget -T 2 -q -O - "$url"
	elif command -v curl >/dev/null 2>&1; then
		curl --max-time 2 -fsSL "$url"
	else
		return 127
	fi
}

mcp_host() {
	local host lan_ip
	host="${MCP_ADDR%:*}"
	if [ "$host" != "0.0.0.0" ] && [ "$host" != "::" ] && [ -n "$host" ]; then
		printf '%s\n' "$host"
		return 0
	fi
	if command -v uci >/dev/null 2>&1; then
		lan_ip="$(uci -q get network.lan.ipaddr 2>/dev/null || true)"
		if [ -n "$lan_ip" ]; then
			printf '%s\n' "$lan_ip"
			return 0
		fi
	fi
	if command -v ip >/dev/null 2>&1; then
		lan_ip="$(ip -4 addr show br-lan 2>/dev/null | sed -n 's/.*inet \([0-9.]*\)\/.*/\1/p' | head -n 1)"
		if [ -n "$lan_ip" ]; then
			printf '%s\n' "$lan_ip"
			return 0
		fi
	fi
	printf '192.168.1.1\n'
}

mcp_endpoint() {
	port="${MCP_ADDR##*:}"
	printf 'http://%s:%s/mcp\n' "$(mcp_host)" "$port"
}

mcp_local_health_endpoint() {
	local host port
	host="${MCP_ADDR%:*}"
	port="${MCP_ADDR##*:}"
	if [ "$host" = "0.0.0.0" ] || [ "$host" = "::" ] || [ -z "$host" ]; then
		host="127.0.0.1"
	fi
	printf 'http://%s:%s/health\n' "$host" "$port"
}

service_status() {
	ok "$(service_body)"
}

runtime_profile_body() {
	local tmp profile mode core core_path exists runtime_source user_profile_path user_profile_exists
	profile=""
	exists=false
	mode=""
	core=""
	core_path=""
	runtime_source=""
	user_profile_path=""
	user_profile_exists=false

	if core_installed; then
		tmp="/tmp/localclash-config-status.$$.json"
		if call_core config status --json > "$tmp" 2>/dev/null; then
			profile="$(jsonfilter -i "$tmp" -e '@.status.runtime_profile.path' 2>/dev/null || true)"
			exists="$(jsonfilter -i "$tmp" -e '@.status.runtime_profile.exists' 2>/dev/null || printf false)"
			mode="$(jsonfilter -i "$tmp" -e '@.status.runtime_profile.mode' 2>/dev/null || true)"
			core="$(jsonfilter -i "$tmp" -e '@.status.runtime_profile.core' 2>/dev/null || true)"
			core_path="$(jsonfilter -i "$tmp" -e '@.status.runtime_profile.core_path' 2>/dev/null || true)"
			runtime_source="$(jsonfilter -i "$tmp" -e '@.status.runtime_profile.runtime_source' 2>/dev/null || true)"
			user_profile_path="$(jsonfilter -i "$tmp" -e '@.status.runtime_profile.user_profile_path' 2>/dev/null || true)"
			user_profile_exists="$(jsonfilter -i "$tmp" -e '@.status.runtime_profile.user_profile_exists' 2>/dev/null || printf false)"
		fi
		rm -f "$tmp"
	fi

	printf '"runtime_profile":{"path":"%s","exists":%s,"mode":"%s","core":"%s","core_path":"%s","runtime_source":"%s","user_profile_path":"%s","user_profile_exists":%s}' "$(json_escape "$profile")" "$exists" "$(json_escape "$mode")" "$(json_escape "$core")" "$(json_escape "$core_path")" "$(json_escape "$runtime_source")" "$(json_escape "$user_profile_path")" "$user_profile_exists"
}

mcp_help() {
	endpoint="$(mcp_endpoint)"
	if [ -f "$MCP_HELP" ]; then
		text="$(sed "s#http://192\\.168\\.6\\.1:8765/mcp#$endpoint#g" "$MCP_HELP")"
	else
		text="请为当前 Agent 会话接入路由器上的 localClash MCP。

MCP 地址：$endpoint

如果你使用 Claude Code，可以先执行：
claude mcp add --transport http localclash $endpoint

配置完成后，请刷新或重启当前 Agent 会话，直到可以看到 localClash MCP 工具。工具可见后，先调用 localClash MCP 的 tools_list，再调用 environment_inspect。根据 environment_inspect 返回的 safety_level 决定下一步：只读检查可以直接执行；写入、运行时、路由器网络接管等变更必须先说明影响并等待用户确认。"
	fi
	ok "\"text\":\"$(json_escape "$text")\",\"endpoint\":\"$(json_escape "$endpoint")\""
}

service_ensure() {
	mkdir -p "$(dirname "$SERVICE")"
	cat > "$SERVICE" <<EOF
#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

CORE="$CORE"
WORKDIR="$STATE_DIR"
MCP_ADDR="$MCP_ADDR"

start_service() {
	if [ ! -x "\$CORE" ]; then
		echo "localClash 核心缺失：\$CORE" >&2
		return 1
	fi
	mkdir -p "\$WORKDIR"
	procd_open_instance
	procd_set_param command /bin/sh -c 'mkdir -p "\$1" && WORKDIR_REAL="\$(cd "\$1" && pwd -P)" && cd / && LOCALCLASH_WORKDIR="\$WORKDIR_REAL" exec "\$2" mcp serve --addr "\$3" --path /mcp' localclash-mcp "\$WORKDIR" "\$CORE" "\$MCP_ADDR"
	procd_set_param respawn
	procd_close_instance
}
EOF
	chmod 755 "$SERVICE"
	log_line "服务脚本已确保存在：$SERVICE"
	ok '"changed":true,"summary":"MCP 服务脚本已确保存在。"'
}

service_start() {
	service_ensure >/dev/null
	if ! core_installed; then
		fail "bootstrap_core_missing" "localClash 核心尚未安装。"
		return 1
	fi
	"$SERVICE" enable >/dev/null 2>&1 || {
		fail "service_enable_failed" "无法启用 localclash-mcp 服务。"
		return 1
	}
	if "$SERVICE" running >/dev/null 2>&1; then
		"$SERVICE" restart >/dev/null 2>&1 || true
	else
		"$SERVICE" start >/dev/null 2>&1 || true
	fi
	sleep 1
	if "$SERVICE" running >/dev/null 2>&1; then
		service_status
		return 0
	fi
	fail "service_start_failed" "无法启动 localclash-mcp 服务。"
	return 1
}

status() {
	local core_ok mihomo_ok dashboard_ok subscription_ok runtime_ok summary runtime_profile base_assets
	core_ok="$(core_installed && echo true || echo false)"
	mihomo_ok="$(mihomo_core_installed && echo true || echo false)"
	dashboard_ok="$(dashboard_installed && echo true || echo false)"
	subscription_ok="$(subscription_configured && echo true || echo false)"
	runtime_ok="$(runtime_running && echo true || echo false)"
	runtime_profile="$(runtime_profile_body)"
	base_assets="$(base_assets_body)"
	summary='"components":{"mihomo":{"installed":'"$mihomo_ok"'},"dashboard":{"installed":'"$dashboard_ok"'}},"subscription":{"configured":'"$subscription_ok"'},"runtime":{"running":'"$runtime_ok"'}'
	printf '{"ok":true,"core":{"installed":%s,"path":"%s"},%s,%s,"mcp_service":{%s},"status":{"ok":true,"changed":false,"summary":"localClash LuCI 状态摘要。",%s,"status":{%s}}}\n' "$core_ok" "$CORE" "$base_assets" "$runtime_profile" "$(service_body)" "$summary" "$summary"
}

component_update() {
	local payload component tmp rc
	payload="$(cat)"
	component="$(jsonfilter -s "$payload" -e '@.component' 2>/dev/null)"
	case "$component" in
		localclash) bootstrap_core ;;
		mihomo|dashboard)
			tmp="/tmp/localclash-component-$component.$$.json"
			log_line "组件更新：正在更新 $component"
			if run_with_heartbeat "组件更新：正在更新 $component" "$tmp" call_core component update "$component" --json; then
				log_line "组件更新：$component 已完成"
				cat "$tmp"
				rm -f "$tmp"
				return 0
			fi
			rc=$?
			log_line "组件更新：$component 更新失败"
			cat "$tmp"
			rm -f "$tmp"
			return "$rc"
			;;
		*) fail "invalid_component" "component 必须是 localclash、mihomo 或 dashboard。" ;;
	esac
}

start_bootstrap_core() {
	local result rc bg_pid
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT" "$TASK_PID"
	: > "$LOG"
	write_task_running "localClash 核心更新任务正在运行。"
	log_line "核心初始化：已加入后台任务队列"
	(
		result="$("$0" call bootstrap_core_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"localClash 核心更新任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		printf '{"ok":true,"running":false,"done":true,"exit_code":%s,"result":%s}\n' "$rc" "$result" > "$TASK_STATUS"
		rm -f "$TASK_PID"
	) >/dev/null 2>&1 &
	bg_pid="$!"
	write_task_pid "$bg_pid"
	ok '"started":true,"running":true,"summary":"localClash 核心更新任务已启动。"'
}

start_component_update() {
	local payload component result rc bg_pid
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	payload="$(strip_ubus_rpc_session "$(cat)")"
	component="$(jsonfilter -s "$payload" -e '@.component' 2>/dev/null)"
	case "$component" in
		localclash|mihomo|dashboard) ;;
		*) fail "invalid_component" "component 必须是 localclash、mihomo 或 dashboard。"; return 1 ;;
	esac
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT" "$TASK_PID"
	: > "$LOG"
	printf '%s\n' "$payload" > "$TASK_INPUT"
	write_task_running "组件更新任务正在运行。"
	log_line "组件更新：$component 已加入后台任务队列"
	(
		result="$("$0" call component_update_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"组件更新任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		printf '{"ok":true,"running":false,"done":true,"exit_code":%s,"result":%s}\n' "$rc" "$result" > "$TASK_STATUS"
		rm -f "$TASK_INPUT" "$TASK_PID"
	) >/dev/null 2>&1 &
	bg_pid="$!"
	write_task_pid "$bg_pid"
	ok '"started":true,"running":true,"summary":"组件更新任务已启动。"'
}

component_update_run() {
	if [ ! -f "$TASK_INPUT" ]; then
		fail "task_input_missing" "组件更新任务输入缺失。"
		return 1
	fi
	with_lock component_update < "$TASK_INPUT"
}

input_to_core_file() {
	local payload tmp rc
	payload="$(cat)"
	payload="$(strip_ubus_rpc_session "$payload")"
	tmp="/tmp/localclash-input-$$.json"
	write_versioned_payload "$payload" > "$tmp"
	call_core "$@" --input "$tmp" --json
	rc=$?
	rm -f "$tmp"
	return "$rc"
}

strip_ubus_rpc_session() {
	printf '%s' "$1" | sed \
		-e 's/"ubus_rpc_session"[[:space:]]*:[[:space:]]*"[^"]*"[[:space:]]*,[[:space:]]*//' \
		-e 's/,[[:space:]]*"ubus_rpc_session"[[:space:]]*:[[:space:]]*"[^"]*"//' \
		-e 's/{[[:space:]]*"ubus_rpc_session"[[:space:]]*:[[:space:]]*"[^"]*"[[:space:]]*}/{}/'
}

write_versioned_payload() {
	local payload body
	payload="$1"
	if printf '%s' "$payload" | jsonfilter -e '@.version' >/dev/null 2>&1; then
		printf '%s' "$payload"
		return 0
	fi

	body="$(printf '%s' "$payload" | sed 's/^[[:space:]]*{//; s/}[[:space:]]*$//')"
	if [ -n "$body" ]; then
		printf '{"version":1,%s}' "$body"
	else
		printf '{"version":1}'
	fi
}

subscription_set() {
	input_to_core_file subscription set
}

subscription_get() {
	local tmp configured urls count url
	urls=""
	count=0

	if ! core_installed; then
		ok '"configured":false,"urls":[],"count":0'
		return 0
	fi

	tmp="/tmp/localclash-subscription-get.$$.json"
	if ! call_core subscription get --json > "$tmp" 2>/dev/null; then
		rm -f "$tmp"
		ok '"configured":false,"urls":[],"count":0'
		return 0
	fi
	configured="$(jsonfilter -i "$tmp" -e '@.status.configured' 2>/dev/null || printf false)"
	if [ "$configured" != "true" ]; then
		rm -f "$tmp"
		ok '"configured":false,"urls":[],"count":0'
		return 0
	fi

	for url in $(jsonfilter -i "$tmp" -e '@.status.urls[*]' 2>/dev/null); do
		if [ "$count" -gt 0 ]; then
			urls="$urls,"
		fi
		urls="$urls\"$(json_escape "$url")\""
		count=$((count + 1))
	done
	rm -f "$tmp"

	ok '"configured":true,"urls":['"$urls"'],"count":'"$count"
}

subscription_save_refresh_file() {
	local input tmpdir
	input="$1"
	tmpdir="$2"

	log_line "订阅设置：正在保存订阅源"
	if ! call_core subscription set --input "$input" --json > "$tmpdir/set.json"; then
		cat "$tmpdir/set.json"
		return 1
	fi

	log_line "订阅设置：正在刷新订阅"
	if ! run_with_heartbeat "订阅设置：正在刷新订阅" "$tmpdir/refresh.json" call_core subscription refresh --json; then
		cat "$tmpdir/refresh.json"
		return 1
	fi
}

subscription_setup_file() {
	local input tmpdir
	input="$1"
	tmpdir="$(mktemp -d /tmp/localclash-subscription.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建临时订阅目录。"
		return 1
	}

	if ! subscription_save_refresh_file "$input" "$tmpdir"; then
		rm -rf "$tmpdir"
		return 1
	fi

	log_line "订阅设置：正在生成 Mihomo 配置"
	if ! run_with_heartbeat "订阅设置：正在生成 Mihomo 配置" "$tmpdir/render.json" call_core config render --json; then
		cat "$tmpdir/render.json"
		rm -rf "$tmpdir"
		return 1
	fi

	rm -rf "$tmpdir"
	log_line "订阅设置：已完成"
	ok '"changed":true,"summary":"订阅已保存、刷新，并已生成配置。","next_actions":["准备好后启动运行时。"]'
}

write_bootstrap_subscription_input() {
	local payload output urls_file count url
	payload="$1"
	output="$2"
	urls_file="$output.urls"
	count=0

	jsonfilter -s "$payload" -e '@.urls[*]' > "$urls_file" 2>/dev/null || true
	printf '{"version":1,"urls":[' > "$output"
	while IFS= read -r url; do
		[ -n "$url" ] || continue
		if [ "$count" -gt 0 ]; then
			printf ',' >> "$output"
		fi
		printf '"%s"' "$(json_escape "$url")" >> "$output"
		count=$((count + 1))
	done < "$urls_file"
	printf ']}\n' >> "$output"
	rm -f "$urls_file"

	[ "$count" -gt 0 ]
}

subscription_setup() {
	local payload input tmpdir rc
	payload="$(strip_ubus_rpc_session "$(cat)")"
	tmpdir="$(mktemp -d /tmp/localclash-subscription-input.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建临时订阅输入目录。"
		return 1
	}
	input="$tmpdir/subscription.json"
	write_versioned_payload "$payload" > "$input"
	subscription_setup_file "$input"
	rc=$?
	rm -rf "$tmpdir"
	return "$rc"
}

start_subscription_setup() {
	local payload result rc bg_pid
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	payload="$(strip_ubus_rpc_session "$(cat)")"
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT" "$TASK_PID"
	: > "$LOG"
	write_versioned_payload "$payload" > "$TASK_INPUT"
	write_task_running "订阅设置任务正在运行。"
	log_line "订阅设置：已加入后台任务队列"
	(
		result="$("$0" call subscription_setup_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"订阅设置任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		printf '{"ok":true,"running":false,"done":true,"exit_code":%s,"result":%s}\n' "$rc" "$result" > "$TASK_STATUS"
		rm -f "$TASK_INPUT" "$TASK_PID"
	) >/dev/null 2>&1 &
	bg_pid="$!"
	write_task_pid "$bg_pid"
	ok '"started":true,"running":true,"summary":"订阅设置任务已启动。"'
}

subscription_setup_run() {
	if [ ! -f "$TASK_INPUT" ]; then
		fail "task_input_missing" "订阅设置任务输入缺失。"
		return 1
	fi
	subscription_setup_file "$TASK_INPUT"
}

