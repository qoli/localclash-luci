#!/bin/sh

CORE="${LOCALCLASH_CORE:-/usr/local/bin/localclash}"
STATE_DIR="${LOCALCLASH_STATE_DIR:-/root/localclash}"
SERVICE="/etc/init.d/localclash-mcp"
LOG="/tmp/localclash-helper.log"
LOCK_DIR="/tmp/localclash-helper.lock"
TASK_STATUS="/tmp/localclash-task-status.json"
TASK_RESULT="/tmp/localclash-task-result.json"
TASK_INPUT="/tmp/localclash-task-input.json"
MIRROR_CACHE_DIR="/tmp/localclash-mirror-cache"
MCP_ADDR="${LOCALCLASH_MCP_ADDR:-0.0.0.0:8765}"
MCP_HELP="/usr/share/localclash/mcp-help.txt"
MANIFEST_URL="${LOCALCLASH_RELEASE_MANIFEST:-https://github.com/qoli/localClash/releases/latest/download/localclash-release-manifest.json}"
GITHUB_MIRROR="${LOCALCLASH_GITHUB_MIRROR:-auto}"
GITHUB_RELEASE_MIRRORS="${LOCALCLASH_GITHUB_RELEASE_MIRRORS:-https://gh.llkk.cc/https://github.com https://gh-proxy.com/https://github.com https://v1.ax/https://github.com https://ghp.xptvhelper.link/https://github.com}"
GITHUB_RAW_MIRRORS="${LOCALCLASH_GITHUB_RAW_MIRRORS:-https://v1.ax/https://raw.githubusercontent.com https://ghp.xptvhelper.link/https://raw.githubusercontent.com https://fastly.jsdelivr.net/gh}"
FETCH_TIMEOUT="${LOCALCLASH_FETCH_TIMEOUT:-20}"
TASK_STEP_TIMEOUT="${LOCALCLASH_TASK_STEP_TIMEOUT:-180}"

json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

ok() {
	printf '{"ok":true,%s}\n' "$1"
}

fail() {
	code="$(json_escape "$1")"
	message="$(json_escape "$2")"
	printf '{"ok":false,"code":"%s","message":"%s","details":{},"next_actions":[]}\n' "$code" "$message"
}

log_line() {
	printf '%s %s\n' "$(date -Iseconds 2>/dev/null || date)" "$*" >> "$LOG"
}

now_epoch() {
	date +%s 2>/dev/null || printf '0\n'
}

write_task_running() {
	printf '{"ok":true,"running":true,"done":false,"started_at":%s,"summary":"%s"}\n' "$(now_epoch)" "$(json_escape "$1")" > "$TASK_STATUS"
}

task_started_at() {
	jsonfilter -i "$TASK_STATUS" -e '@.started_at' 2>/dev/null || printf '0\n'
}

lock_pid_alive() {
	local pid
	[ -f "$LOCK_DIR/pid" ] || return 1
	pid="$(cat "$LOCK_DIR/pid" 2>/dev/null)"
	[ -n "$pid" ] || return 1
	kill -0 "$pid" 2>/dev/null
}

clear_stale_lock() {
	[ -d "$LOCK_DIR" ] || return 0
	if ! lock_pid_alive; then
		rm -rf "$LOCK_DIR" 2>/dev/null || true
		log_line "任务锁：已清理失效任务锁"
	fi
}

write_task_stale_result() {
	local result
	result='{"ok":false,"code":"task_interrupted","message":"初始化任务已中断，请重试。","details":{},"next_actions":["点击一键初始化重试。"]}'
	printf '%s\n' "$result" > "$TASK_RESULT"
	printf '{"ok":true,"running":false,"done":true,"exit_code":124,"result":%s}\n' "$result" > "$TASK_STATUS"
}

reconcile_task_status() {
	local started age
	[ -f "$TASK_STATUS" ] || return 0
	grep -q '"running":true' "$TASK_STATUS" 2>/dev/null || return 0
	clear_stale_lock
	[ -d "$LOCK_DIR" ] && return 0
	started="$(task_started_at)"
	age=$(( $(now_epoch) - started ))
	[ "$started" -gt 0 ] && [ "$age" -lt 10 ] && return 0
	if ! ps w 2>/dev/null | grep -q '[l]ocalclash .*_run'; then
		log_line "任务状态：检测到后台任务已中断"
		write_task_stale_result
	fi
}

with_lock() {
	waited=0
	while ! mkdir "$LOCK_DIR" 2>/dev/null; do
		clear_stale_lock
		if [ "$waited" -ge 120 ]; then
			log_line "等待任务锁超时：$*"
			fail "task_locked" "另一个 localClash 任务仍在运行，请稍后再试。"
			return 1
		fi
		waited=$((waited + 1))
		sleep 1
	done
	printf '%s\n' "$$" > "$LOCK_DIR/pid"
	trap 'rm -rf "$LOCK_DIR" 2>/dev/null || true' EXIT INT TERM
	"$@"
	rc=$?
	rm -rf "$LOCK_DIR" 2>/dev/null || true
	trap - EXIT INT TERM
	return "$rc"
}

run_with_heartbeat() {
	local label output pid elapsed rc
	label="$1"
	output="$2"
	shift 2
	elapsed=0
	( "$@" > "$output" ) &
	pid="$!"
	while kill -0 "$pid" 2>/dev/null; do
		sleep 5
		if kill -0 "$pid" 2>/dev/null; then
			elapsed=$((elapsed + 5))
			log_line "$label：仍在执行（${elapsed}s）"
			if [ "$TASK_STEP_TIMEOUT" -gt 0 ] && [ "$elapsed" -ge "$TASK_STEP_TIMEOUT" ]; then
				log_line "$label：超过 ${TASK_STEP_TIMEOUT}s，已停止等待"
				kill "$pid" 2>/dev/null || true
				sleep 2
				kill -9 "$pid" 2>/dev/null || true
				wait "$pid" 2>/dev/null || true
				printf '{"ok":false,"code":"step_timeout","message":"%s 超时，请检查路由器是否能访问下载源，或稍后重试。","details":{"timeout_seconds":%s},"next_actions":["确认路由器可以访问下载源后重试。"]}\n' "$(json_escape "$label")" "$TASK_STEP_TIMEOUT" > "$output"
				return 124
			fi
		fi
	done
	wait "$pid"
	rc="$?"
	return "$rc"
}

fetch_single_url() {
	local url output
	url="$1"
	output="$2"
	if command -v uclient-fetch >/dev/null 2>&1; then
		fetch_with_watchdog "$url" uclient-fetch -T "$FETCH_TIMEOUT" -q -O "$output" "$url"
	elif command -v wget >/dev/null 2>&1; then
		fetch_with_watchdog "$url" wget -T "$FETCH_TIMEOUT" -q -O "$output" "$url"
	elif command -v curl >/dev/null 2>&1; then
		fetch_with_watchdog "$url" curl --max-time "$FETCH_TIMEOUT" -fsSL "$url" -o "$output"
	else
		return 1
	fi
}

fetch_with_watchdog() {
	local label pid watchdog elapsed rc
	label="$1"
	shift
	"$@" &
	pid="$!"
	(
		elapsed=0
		while kill -0 "$pid" 2>/dev/null; do
			sleep 5
			if kill -0 "$pid" 2>/dev/null; then
				elapsed=$((elapsed + 5))
				log_line "下载：等待 $label（${elapsed}s）"
				if [ "$elapsed" -ge "$FETCH_TIMEOUT" ]; then
					kill "$pid" 2>/dev/null || exit 0
					sleep 2
					kill -9 "$pid" 2>/dev/null || true
					exit 0
				fi
			fi
		done
	) &
	watchdog="$!"
	wait "$pid"
	rc="$?"
	kill "$watchdog" 2>/dev/null || true
	return "$rc"
}

probe_url_for_mirror() {
	local kind mirror
	kind="$1"
	mirror="$2"
	case "$kind:$mirror" in
		release:*)
			printf '%s/qoli/syncnext-api/main/pass.txt\n' "$(printf '%s' "$mirror" | sed 's#https://github.com#https://raw.githubusercontent.com#')"
			;;
		raw:https://fastly.jsdelivr.net/gh)
			printf 'https://fastly.jsdelivr.net/gh/qoli/syncnext-api@main/pass.txt\n'
			;;
		raw:*)
			printf '%s/qoli/syncnext-api/main/pass.txt\n' "$mirror"
			;;
	esac
}

mirror_probe_ok() {
	local kind mirror probe tmp body
	kind="$1"
	mirror="$2"
	probe="$(probe_url_for_mirror "$kind" "$mirror")"
	tmp="/tmp/localclash-mirror-probe.$$"
	rm -f "$tmp"
	log_line "下载：探测 $kind 镜像 $mirror"
	if ! fetch_single_url "$probe" "$tmp"; then
		rm -f "$tmp"
		return 1
	fi
	body="$(tr -d '\r\n' < "$tmp" 2>/dev/null)"
	rm -f "$tmp"
	[ "$body" = "pass" ]
}

select_github_mirror() {
	local kind mirrors mirror cache
	kind="$1"
	mirrors="$2"
	mkdir -p "$MIRROR_CACHE_DIR"
	cache="$MIRROR_CACHE_DIR/$kind"

	if [ -f "$cache" ]; then
		mirror="$(cat "$cache")"
		if [ -n "$mirror" ]; then
			printf '%s\n' "$mirror"
			return 0
		fi
	fi

	for mirror in $mirrors; do
		if mirror_probe_ok "$kind" "$mirror"; then
			printf '%s\n' "$mirror" > "$cache"
			log_line "下载：已选择 $kind 镜像 $mirror"
			printf '%s\n' "$mirror"
			return 0
		fi
	done

	rm -f "$cache"
	return 1
}

cache_github_mirror() {
	local kind mirror cache current
	kind="$1"
	mirror="$2"
	[ -n "$mirror" ] || return 0
	mkdir -p "$MIRROR_CACHE_DIR"
	cache="$MIRROR_CACHE_DIR/$kind"
	current="$(cat "$cache" 2>/dev/null || true)"
	if [ "$current" != "$mirror" ]; then
		printf '%s\n' "$mirror" > "$cache"
		log_line "下载：已确认 $kind 镜像 $mirror"
	fi
}

invalidate_github_mirror() {
	local kind mirror cache current
	kind="$1"
	mirror="$2"
	[ -n "$mirror" ] || return 0
	cache="$MIRROR_CACHE_DIR/$kind"
	current="$(cat "$cache" 2>/dev/null || true)"
	if [ "$current" = "$mirror" ]; then
		rm -f "$cache"
		log_line "下载：已丢弃 $kind 镜像 $mirror"
	fi
}

github_url_kind() {
	case "$1" in
		https://github.com/*) printf 'release\n' ;;
		https://raw.githubusercontent.com/*) printf 'raw\n' ;;
	esac
}

candidate_mirror_for_kind() {
	local kind candidate mirrors mirror
	kind="$1"
	candidate="$2"
	case "$kind" in
		release) mirrors="$GITHUB_RELEASE_MIRRORS" ;;
		raw) mirrors="$GITHUB_RAW_MIRRORS" ;;
		*) return 1 ;;
	esac
	for mirror in $mirrors; do
		case "$candidate" in
			"$mirror"/*)
				printf '%s\n' "$mirror"
				return 0
				;;
		esac
	done
	return 1
}

note_github_candidate_success() {
	local url candidate kind mirror
	url="$1"
	candidate="$2"
	kind="$(github_url_kind "$url")"
	[ -n "$kind" ] || return 0
	mirror="$(candidate_mirror_for_kind "$kind" "$candidate" || true)"
	cache_github_mirror "$kind" "$mirror"
}

note_github_candidate_failure() {
	local url candidate kind mirror
	url="$1"
	candidate="$2"
	kind="$(github_url_kind "$url")"
	[ -n "$kind" ] || return 0
	mirror="$(candidate_mirror_for_kind "$kind" "$candidate" || true)"
	invalidate_github_mirror "$kind" "$mirror"
}

raw_github_to_jsdelivr() {
	local rest owner repo branch path
	rest="${1#https://raw.githubusercontent.com/}"
	owner="${rest%%/*}"
	rest="${rest#*/}"
	repo="${rest%%/*}"
	rest="${rest#*/}"
	branch="${rest%%/*}"
	path="${rest#*/}"
	if [ -n "$owner" ] && [ -n "$repo" ] && [ -n "$branch" ] && [ -n "$path" ]; then
		printf 'https://fastly.jsdelivr.net/gh/%s/%s@%s/%s\n' "$owner" "$repo" "$branch" "$path"
	fi
}

github_download_candidates() {
	local url mirror selected
	url="$1"
	if [ "$GITHUB_MIRROR" = "0" ] || [ "$GITHUB_MIRROR" = "off" ] || [ "$GITHUB_MIRROR" = "false" ]; then
		printf '%s\n' "$url"
		return 0
	fi

	case "$url" in
		https://github.com/*)
			selected="$(select_github_mirror release "$GITHUB_RELEASE_MIRRORS" 2>/dev/null || true)"
			if [ -n "$selected" ]; then
				printf '%s%s\n' "$selected" "${url#https://github.com}"
			fi
			for mirror in $GITHUB_RELEASE_MIRRORS; do
				[ "$mirror" = "$selected" ] || printf '%s%s\n' "$mirror" "${url#https://github.com}"
			done
			;;
		https://raw.githubusercontent.com/*)
			selected="$(select_github_mirror raw "$GITHUB_RAW_MIRRORS" 2>/dev/null || true)"
			if [ -n "$selected" ]; then
				case "$selected" in
					https://fastly.jsdelivr.net/gh) raw_github_to_jsdelivr "$url" ;;
					*) printf '%s%s\n' "$selected" "${url#https://raw.githubusercontent.com}" ;;
				esac
			fi
			for mirror in $GITHUB_RAW_MIRRORS; do
				[ "$mirror" = "$selected" ] && continue
				case "$mirror" in
					https://fastly.jsdelivr.net/gh) raw_github_to_jsdelivr "$url" ;;
					*) printf '%s%s\n' "$mirror" "${url#https://raw.githubusercontent.com}" ;;
				esac
			done
			;;
	esac

	printf '%s\n' "$url"
}

fetch_url() {
	local url output tmp candidate
	url="$1"
	output="$2"
	tmp="$output.download.$$"
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			mv "$tmp" "$output"
			note_github_candidate_success "$url" "$candidate"
			return 0
		fi
		note_github_candidate_failure "$url" "$candidate"
		rm -f "$tmp"
	done
	return 1
}

fetch_manifest() {
	local url output tmp candidate
	url="$1"
	output="$2"
	tmp="$output.download.$$"
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			if jsonfilter -i "$tmp" -e '@.version' >/dev/null 2>&1; then
				mv "$tmp" "$output"
				note_github_candidate_success "$url" "$candidate"
				return 0
			fi
			log_line "下载：$candidate 返回的 Release 清单无效"
			note_github_candidate_failure "$url" "$candidate"
		else
			note_github_candidate_failure "$url" "$candidate"
		fi
		rm -f "$tmp"
	done
	return 1
}

fetch_url_verified() {
	local url output expected_sha tmp candidate actual_sha
	url="$1"
	output="$2"
	expected_sha="$3"
	tmp="$output.download.$$"
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			actual_sha="$(sha256sum "$tmp" | cut -d ' ' -f 1)"
			if [ "$actual_sha" = "$expected_sha" ]; then
				mv "$tmp" "$output"
				note_github_candidate_success "$url" "$candidate"
				return 0
			fi
			log_line "下载：$candidate 校验和不匹配"
			note_github_candidate_failure "$url" "$candidate"
		else
			note_github_candidate_failure "$url" "$candidate"
		fi
		rm -f "$tmp"
	done
	return 1
}

router_arch() {
	case "$(uname -m)" in
		aarch64|arm64) echo "arm64" ;;
		x86_64|amd64) echo "amd64" ;;
		*) return 1 ;;
	esac
}

core_installed() {
	[ -x "$CORE" ]
}

call_core() {
	if ! core_installed; then
		fail "bootstrap_core_missing" "localClash 核心尚未安装。"
		return 1
	fi
	mkdir -p "$STATE_DIR"
	(cd "$STATE_DIR" && "$CORE" "$@") 2>>"$LOG"
}

runtime_pid_file() {
	printf '%s/.runtime/mihomo/mihomo.pid\n' "$STATE_DIR"
}

clear_zombie_runtime_pid() {
	local pid_file pid
	pid_file="$(runtime_pid_file)"
	[ -f "$pid_file" ] || return 0
	pid="$(cat "$pid_file" 2>/dev/null)"
	[ -n "$pid" ] || return 0
	if runtime_pid_zombie "$pid"; then
		rm -f "$pid_file"
		log_line "runtime：已清理僵尸进程 PID 文件，pid=$pid"
	fi
}

runtime_pid_alive() {
	local pid
	pid="$1"
	[ -n "$pid" ] || return 1
	[ -d "/proc/$pid" ] || return 1
	kill -0 "$pid" 2>/dev/null || return 1
	! runtime_pid_zombie "$pid"
}

runtime_pid_zombie() {
	local pid
	pid="$1"
	[ -n "$pid" ] || return 1
	[ -r "/proc/$pid/status" ] || return 1
	awk '$1 == "State:" && $2 == "Z" { found = 1 } END { exit found ? 0 : 1 }' "/proc/$pid/status" 2>/dev/null
}

wait_runtime_pid_exit() {
	local pid waited limit
	pid="$1"
	limit="$2"
	waited=0
	while runtime_pid_alive "$pid"; do
		[ "$waited" -ge "$limit" ] && return 1
		sleep 1
		waited=$((waited + 1))
	done
	return 0
}

runtime_force_cleanup() {
	local pid_file pid
	pid_file="$(runtime_pid_file)"
	[ -f "$pid_file" ] || return 0
	pid="$(cat "$pid_file" 2>/dev/null)"
	[ -n "$pid" ] || {
		rm -f "$pid_file"
		return 1
	}

	if runtime_pid_zombie "$pid"; then
		rm -f "$pid_file"
		log_line "runtime：已清理僵尸进程 PID 文件，pid=$pid"
		return 1
	fi

	if ! runtime_pid_alive "$pid"; then
		rm -f "$pid_file"
		return 1
	fi

	kill "$pid" 2>/dev/null || true
	if ! wait_runtime_pid_exit "$pid" 5; then
		kill -9 "$pid" 2>/dev/null || true
		wait_runtime_pid_exit "$pid" 3 || return 2
	fi
	rm -f "$pid_file"
	log_line "runtime：已强制停止残留进程，pid=$pid"
	return 1
}

runtime_stop() {
	local tmp rc cleanup_rc
	tmp="/tmp/localclash-runtime-stop.$$"
	call_core runtime stop --json > "$tmp"
	rc=$?
	clear_zombie_runtime_pid
	runtime_force_cleanup
	cleanup_rc=$?
	if [ "$cleanup_rc" -eq 1 ]; then
		ok '"changed":true,"summary":"Runtime stop completed.","status":{"stopped":true,"forced_cleanup":true},"changes":["runtime_stopped"],"warnings":[],"next_actions":[]'
	elif [ "$cleanup_rc" -eq 2 ]; then
		fail "runtime_stop_failed" "运行时停止命令已执行，但残留进程无法被清理。"
		rc=1
	elif grep -q "runtime did not stop before timeout" "$tmp" && ! runtime_running; then
		ok '"changed":true,"summary":"Runtime stop completed.","status":{"stopped":true,"forced_cleanup":true},"changes":["runtime_stopped"],"warnings":[],"next_actions":[]'
	else
		cat "$tmp"
	fi
	rm -f "$tmp"
	return "$rc"
}

runtime_start() {
	clear_zombie_runtime_pid
	call_core runtime start --json
}

runtime_restart() {
	local stop_output
	stop_output="/tmp/localclash-runtime-restart-stop.$$"
	if ! runtime_stop > "$stop_output"; then
		cat "$stop_output"
		rm -f "$stop_output"
		return 1
	fi
	rm -f "$stop_output"
	call_core runtime start --json
}

base_assets_installed() {
	[ -f "$STATE_DIR/policies/loyalsoldier.yaml" ] || return 1
	[ -f "$STATE_DIR/policy-templates/localclash-default.yaml" ] || return 1
	[ -f "$STATE_DIR/.runtime/mihomo/Country.mmdb" ] || return 1
	[ -f "$STATE_DIR/.runtime/mihomo/geoip.dat" ] || return 1
	[ -f "$STATE_DIR/.runtime/mihomo/geosite.dat" ] || return 1
	[ -f "$STATE_DIR/.runtime/mihomo/ASN.mmdb" ] || return 1
	for source in "$STATE_DIR"/rule-sources/*.yaml; do
		[ -e "$source" ] && return 0
	done
	return 1
}

mihomo_core_installed() {
	local arch
	arch="$(router_arch 2>/dev/null)" || return 1
	[ -x "$STATE_DIR/bin/linux-$arch/mihomo-smart" ] || [ -x "$STATE_DIR/bin/linux-$arch/mihomo-meta" ]
}

dashboard_installed() {
	for asset in "$STATE_DIR"/.runtime/mihomo/ui/*; do
		[ -e "$asset" ] && return 0
	done
	return 1
}

subscription_configured() {
	[ -f "$STATE_DIR/localclash-subscriptions.yaml" ] || return 1
	[ -f "$STATE_DIR/subscription.yaml" ] || return 1
	for source in "$STATE_DIR"/.runtime/subscriptions/*.yaml; do
		[ -e "$source" ] && return 0
	done
	return 1
}

runtime_running() {
	local pid_file pid
	pid_file="$(runtime_pid_file)"
	[ -f "$pid_file" ] || return 1
	pid="$(cat "$pid_file" 2>/dev/null)"
	[ -n "$pid" ] || return 1
	runtime_pid_alive "$pid"
}

service_body() {
	local installed enabled running pid endpoint health_endpoint health_probe health_body healthy last_error
	installed=false
	enabled=false
	running=false
	pid=0
	healthy=false
	last_error=""
	if [ -x "$SERVICE" ]; then
		installed=true
		"$SERVICE" enabled >/dev/null 2>&1 && enabled=true
		if "$SERVICE" running >/dev/null 2>&1; then
			running=true
			pid="$(ps w 2>/dev/null | awk '/[l]ocalclash mcp serve/ { print $1; exit }')"
			[ -n "$pid" ] || pid=0
		fi
	fi
	endpoint="$(mcp_endpoint)"
	health_endpoint="${endpoint%/mcp}/health"
	if [ "$running" = true ]; then
		health_probe="$(mcp_local_health_endpoint)"
		health_body="$(mcp_health_body "$health_probe" 2>/tmp/localclash-mcp-health.err || true)"
		if printf '%s' "$health_body" | grep -q '"status":"ok"'; then
			healthy=true
		else
			last_error="$(cat /tmp/localclash-mcp-health.err 2>/dev/null || true)"
			[ -n "$last_error" ] || last_error="MCP 健康检查未返回 ok。"
		fi
		rm -f /tmp/localclash-mcp-health.err
	fi
	printf '"service":{"name":"localclash-mcp","installed":%s,"enabled":%s,"running":%s,"pid":%s},"mcp":{"endpoint":"%s","health_endpoint":"%s","healthy":%s,"last_error":"%s"}' "$installed" "$enabled" "$running" "$pid" "$(json_escape "$endpoint")" "$(json_escape "$health_endpoint")" "$healthy" "$(json_escape "$last_error")"
}

mcp_health_body() {
	local url
	url="$1"
	if command -v uclient-fetch >/dev/null 2>&1; then
		uclient-fetch -T 2 -q -O - "$url"
	elif command -v wget >/dev/null 2>&1; then
		wget -T 2 -q -O - "$url"
	elif command -v curl >/dev/null 2>&1; then
		curl --max-time 2 -fsSL "$url"
	else
		return 127
	fi
}

mcp_host() {
	local host lan_ip
	host="${MCP_ADDR%:*}"
	if [ "$host" != "0.0.0.0" ] && [ "$host" != "::" ] && [ -n "$host" ]; then
		printf '%s\n' "$host"
		return 0
	fi
	if command -v uci >/dev/null 2>&1; then
		lan_ip="$(uci -q get network.lan.ipaddr 2>/dev/null || true)"
		if [ -n "$lan_ip" ]; then
			printf '%s\n' "$lan_ip"
			return 0
		fi
	fi
	if command -v ip >/dev/null 2>&1; then
		lan_ip="$(ip -4 addr show br-lan 2>/dev/null | sed -n 's/.*inet \([0-9.]*\)\/.*/\1/p' | head -n 1)"
		if [ -n "$lan_ip" ]; then
			printf '%s\n' "$lan_ip"
			return 0
		fi
	fi
	printf '192.168.1.1\n'
}

mcp_endpoint() {
	port="${MCP_ADDR##*:}"
	printf 'http://%s:%s/mcp\n' "$(mcp_host)" "$port"
}

mcp_local_health_endpoint() {
	local host port
	host="${MCP_ADDR%:*}"
	port="${MCP_ADDR##*:}"
	if [ "$host" = "0.0.0.0" ] || [ "$host" = "::" ] || [ -z "$host" ]; then
		host="127.0.0.1"
	fi
	printf 'http://%s:%s/health\n' "$host" "$port"
}

service_status() {
	ok "$(service_body)"
}

runtime_profile_body() {
	local profile mode core core_path exists
	profile="$STATE_DIR/localclash-runtime.yaml"
	exists=false
	mode=""
	core=""
	core_path=""

	if [ -f "$profile" ]; then
		exists=true
		mode="$(awk -F: '$1 == "mode" { gsub(/^[ \t]+|[ \t]+$/, "", $2); print $2; exit }' "$profile" 2>/dev/null)"
		core="$(awk -F: '$1 == "core" { gsub(/^[ \t]+|[ \t]+$/, "", $2); print $2; exit }' "$profile" 2>/dev/null)"
		if [ -n "$core" ]; then
			core_path="$(awk -v target="$core" '
				/^[^[:space:]]/ { section = $1; sub(":", "", section); in_core = 0 }
				section == "cores" && $1 == target ":" { in_core = 1; next }
				section == "cores" && in_core && $1 == "path:" { print $2; exit }
			' "$profile" 2>/dev/null)"
		fi
	fi

	printf '"runtime_profile":{"path":"%s","exists":%s,"mode":"%s","core":"%s","core_path":"%s"}' "$(json_escape "$profile")" "$exists" "$(json_escape "$mode")" "$(json_escape "$core")" "$(json_escape "$core_path")"
}

mcp_help() {
	endpoint="$(mcp_endpoint)"
	if [ -f "$MCP_HELP" ]; then
		text="$(sed "s#http://192\\.168\\.6\\.1:8765/mcp#$endpoint#g" "$MCP_HELP")"
	else
		text="请连接 localClash MCP：$endpoint。请先调用 tools_list 和 environment_inspect，再根据返回的 safety_level 决定是否执行 runtime 或路由器网络接管变更。"
	fi
	ok "\"text\":\"$(json_escape "$text")\",\"endpoint\":\"$(json_escape "$endpoint")\""
}

service_ensure() {
	mkdir -p "$(dirname "$SERVICE")"
	cat > "$SERVICE" <<EOF
#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

CORE="$CORE"
WORKDIR="$STATE_DIR"
MCP_ADDR="$MCP_ADDR"

start_service() {
	if [ ! -x "\$CORE" ]; then
		echo "localClash 核心缺失：\$CORE" >&2
		return 1
	fi
	mkdir -p "\$WORKDIR"
	procd_open_instance
	procd_set_param command /bin/sh -c 'cd "\$1" && exec "\$2" mcp serve --addr "\$3" --path /mcp' localclash-mcp "\$WORKDIR" "\$CORE" "\$MCP_ADDR"
	procd_set_param respawn
	procd_close_instance
}
EOF
	chmod 755 "$SERVICE"
	log_line "服务脚本已确保存在：$SERVICE"
	ok '"changed":true,"summary":"MCP 服务脚本已确保存在。"'
}

service_start() {
	service_ensure >/dev/null
	if ! core_installed; then
		fail "bootstrap_core_missing" "localClash 核心尚未安装。"
		return 1
	fi
	"$SERVICE" enable >/dev/null 2>&1 || {
		fail "service_enable_failed" "无法启用 localclash-mcp 服务。"
		return 1
	}
	if "$SERVICE" running >/dev/null 2>&1; then
		"$SERVICE" restart >/dev/null 2>&1 || true
	else
		"$SERVICE" start >/dev/null 2>&1 || true
	fi
	sleep 1
	if "$SERVICE" running >/dev/null 2>&1; then
		service_status
		return 0
	fi
	fail "service_start_failed" "无法启动 localclash-mcp 服务。"
	return 1
}

status() {
	local core_ok assets_ok mihomo_ok dashboard_ok subscription_ok runtime_ok summary runtime_profile
	clear_zombie_runtime_pid
	core_ok="$(core_installed && echo true || echo false)"
	assets_ok="$(base_assets_installed && echo true || echo false)"
	mihomo_ok="$(mihomo_core_installed && echo true || echo false)"
	dashboard_ok="$(dashboard_installed && echo true || echo false)"
	subscription_ok="$(subscription_configured && echo true || echo false)"
	runtime_ok="$(runtime_running && echo true || echo false)"
	runtime_profile="$(runtime_profile_body)"
	summary='"components":{"mihomo":{"installed":'"$mihomo_ok"'},"dashboard":{"installed":'"$dashboard_ok"'}},"subscription":{"configured":'"$subscription_ok"'},"runtime":{"running":'"$runtime_ok"'}'
	printf '{"ok":true,"core":{"installed":%s,"path":"%s"},"base_assets":{"installed":%s,"path":"%s"},%s,"mcp_service":{%s},"status":{"ok":true,"changed":false,"summary":"localClash LuCI 状态摘要。",%s,"status":{%s}}}\n' "$core_ok" "$CORE" "$assets_ok" "$STATE_DIR" "$runtime_profile" "$(service_body)" "$summary" "$summary"
}

component_update() {
	local payload component tmp rc
	payload="$(cat)"
	component="$(jsonfilter -s "$payload" -e '@.component' 2>/dev/null)"
	case "$component" in
		localclash) bootstrap_core ;;
		mihomo|dashboard)
			tmp="/tmp/localclash-component-$component.$$.json"
			log_line "组件更新：正在更新 $component"
			if run_with_heartbeat "组件更新：正在更新 $component" "$tmp" call_core component update "$component" --json; then
				log_line "组件更新：$component 已完成"
				cat "$tmp"
				rm -f "$tmp"
				return 0
			fi
			rc=$?
			log_line "组件更新：$component 更新失败"
			cat "$tmp"
			rm -f "$tmp"
			return "$rc"
			;;
		*) fail "invalid_component" "component 必须是 localclash、mihomo 或 dashboard。" ;;
	esac
}

start_bootstrap_core() {
	local result rc
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT"
	: > "$LOG"
	write_task_running "localClash 核心更新任务正在运行。"
	log_line "核心初始化：已加入后台任务队列"
	(
		result="$("$0" call bootstrap_core_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"localClash 核心更新任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		printf '{"ok":true,"running":false,"done":true,"exit_code":%s,"result":%s}\n' "$rc" "$result" > "$TASK_STATUS"
	) >/dev/null 2>&1 &
	ok '"started":true,"running":true,"summary":"localClash 核心更新任务已启动。"'
}

start_component_update() {
	local payload component result rc
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	payload="$(strip_ubus_rpc_session "$(cat)")"
	component="$(jsonfilter -s "$payload" -e '@.component' 2>/dev/null)"
	case "$component" in
		localclash|mihomo|dashboard) ;;
		*) fail "invalid_component" "component 必须是 localclash、mihomo 或 dashboard。"; return 1 ;;
	esac
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT"
	: > "$LOG"
	printf '%s\n' "$payload" > "$TASK_INPUT"
	write_task_running "组件更新任务正在运行。"
	log_line "组件更新：$component 已加入后台任务队列"
	(
		result="$("$0" call component_update_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"组件更新任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		printf '{"ok":true,"running":false,"done":true,"exit_code":%s,"result":%s}\n' "$rc" "$result" > "$TASK_STATUS"
		rm -f "$TASK_INPUT"
	) >/dev/null 2>&1 &
	ok '"started":true,"running":true,"summary":"组件更新任务已启动。"'
}

component_update_run() {
	if [ ! -f "$TASK_INPUT" ]; then
		fail "task_input_missing" "组件更新任务输入缺失。"
		return 1
	fi
	with_lock component_update < "$TASK_INPUT"
}

input_to_core_file() {
	local payload tmp rc
	payload="$(cat)"
	payload="$(strip_ubus_rpc_session "$payload")"
	tmp="/tmp/localclash-input-$$.json"
	write_versioned_payload "$payload" > "$tmp"
	call_core "$@" --input "$tmp" --json
	rc=$?
	rm -f "$tmp"
	return "$rc"
}

strip_ubus_rpc_session() {
	printf '%s' "$1" | sed \
		-e 's/"ubus_rpc_session"[[:space:]]*:[[:space:]]*"[^"]*"[[:space:]]*,[[:space:]]*//' \
		-e 's/,[[:space:]]*"ubus_rpc_session"[[:space:]]*:[[:space:]]*"[^"]*"//' \
		-e 's/{[[:space:]]*"ubus_rpc_session"[[:space:]]*:[[:space:]]*"[^"]*"[[:space:]]*}/{}/'
}

write_versioned_payload() {
	local payload body
	payload="$1"
	if printf '%s' "$payload" | jsonfilter -e '@.version' >/dev/null 2>&1; then
		printf '%s' "$payload"
		return 0
	fi

	body="$(printf '%s' "$payload" | sed 's/^[[:space:]]*{//; s/}[[:space:]]*$//')"
	if [ -n "$body" ]; then
		printf '{"version":1,%s}' "$body"
	else
		printf '{"version":1}'
	fi
}

subscription_set() {
	input_to_core_file subscription set
}

subscription_get() {
	local config urls count line url
	config="$STATE_DIR/localclash-subscriptions.yaml"
	urls=""
	count=0

	if [ ! -f "$config" ]; then
		ok '"configured":false,"urls":[],"count":0'
		return 0
	fi

	while IFS= read -r line; do
		url="$(printf '%s\n' "$line" | sed -n 's/^[[:space:]]*url:[[:space:]]*//p')"
		[ -n "$url" ] || continue
		case "$url" in
			\"*\") url="${url#\"}"; url="${url%\"}" ;;
			\'*\') url="${url#\'}"; url="${url%\'}" ;;
		esac
		if [ "$count" -gt 0 ]; then
			urls="$urls,"
		fi
		urls="$urls\"$(json_escape "$url")\""
		count=$((count + 1))
	done < "$config"

	ok '"configured":true,"urls":['"$urls"'],"count":'"$count"
}

subscription_setup_file() {
	local input tmpdir
	input="$1"
	tmpdir="$(mktemp -d /tmp/localclash-subscription.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建临时订阅目录。"
		return 1
	}

	log_line "订阅设置：正在保存订阅源"
	if ! call_core subscription set --input "$input" --json > "$tmpdir/set.json"; then
		cat "$tmpdir/set.json"
		rm -rf "$tmpdir"
		return 1
	fi

	log_line "订阅设置：正在刷新订阅"
	if ! run_with_heartbeat "订阅设置：正在刷新订阅" "$tmpdir/refresh.json" call_core subscription refresh --json; then
		cat "$tmpdir/refresh.json"
		rm -rf "$tmpdir"
		return 1
	fi

	log_line "订阅设置：正在生成 Mihomo 配置"
	if ! run_with_heartbeat "订阅设置：正在生成 Mihomo 配置" "$tmpdir/render.json" call_core config render --json; then
		cat "$tmpdir/render.json"
		rm -rf "$tmpdir"
		return 1
	fi

	rm -rf "$tmpdir"
	log_line "订阅设置：已完成"
	ok '"changed":true,"summary":"订阅已保存、刷新，并已生成配置。","next_actions":["准备好后启动运行时。"]'
}

subscription_setup() {
	local payload input tmpdir rc
	payload="$(strip_ubus_rpc_session "$(cat)")"
	tmpdir="$(mktemp -d /tmp/localclash-subscription-input.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建临时订阅输入目录。"
		return 1
	}
	input="$tmpdir/subscription.json"
	write_versioned_payload "$payload" > "$input"
	subscription_setup_file "$input"
	rc=$?
	rm -rf "$tmpdir"
	return "$rc"
}

start_subscription_setup() {
	local payload result rc
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
