config_reset() {
	local deleted path
	if runtime_running; then
		fail "runtime_running" "Mihomo 运行时正在运行，请先停止运行时再执行配置复位。"
		return 1
	fi
	deleted=""
	for path in \
		"$STATE_DIR/generated" \
		"$STATE_DIR/profiles" \
		"$STATE_DIR/localclash.yaml" \
		"$STATE_DIR/localclash-packs.yaml" \
		"$STATE_DIR/localclash-subscriptions.yaml" \
		"$STATE_DIR/localclash-runtime.yaml" \
		"$STATE_DIR/.runtime/subscriptions" \
		"$STATE_DIR"/subscription*.yaml
	do
		[ -e "$path" ] || continue
		rm -rf "$path" || {
			fail "config_reset_failed" "配置复位失败，请检查文件权限。"
			return 1
		}
		[ -n "$deleted" ] && deleted="$deleted,"
		deleted="$deleted\"$(json_escape "${path#$STATE_DIR/}")\""
	done
	log_line "配置复位：已清理配置并保留核心、二进制和基础资源"
