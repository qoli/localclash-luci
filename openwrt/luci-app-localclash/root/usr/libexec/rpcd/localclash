#!/bin/sh

CORE="${LOCALCLASH_CORE:-/usr/local/bin/localclash}"
STATE_DIR="${LOCALCLASH_STATE_DIR:-/root/localclash}"
SERVICE="/etc/init.d/localclash-mcp"
LOG="/tmp/localclash-helper.log"
LOCK_DIR="/tmp/localclash-helper.lock"
TASK_STATUS="/tmp/localclash-task-status.json"
TASK_RESULT="/tmp/localclash-task-result.json"
TASK_INPUT="/tmp/localclash-task-input.json"
TASK_PID="/tmp/localclash-task.pid"
MIRROR_CACHE_DIR="/tmp/localclash-mirror-cache"
MCP_ADDR="${LOCALCLASH_MCP_ADDR:-0.0.0.0:8765}"
MCP_HELP="/usr/share/localclash/mcp-help.txt"
MANIFEST_URL="${LOCALCLASH_RELEASE_MANIFEST:-https://github.com/qoli/localClash/releases/latest/download/localclash-release-manifest.json}"
GITHUB_MIRROR="${LOCALCLASH_GITHUB_MIRROR:-auto}"
GITHUB_RELEASE_MIRRORS="${LOCALCLASH_GITHUB_RELEASE_MIRRORS:-https://gh-proxy.com/https://github.com https://ghproxy.imciel.com/https://github.com https://gitproxy.mrhjx.cn/https://github.com https://gh.jasonzeng.dev/https://github.com https://gh.monlor.com/https://github.com https://gh.noki.icu/https://github.com https://ghfast.top/https://github.com}"
GITHUB_RAW_MIRRORS="${LOCALCLASH_GITHUB_RAW_MIRRORS:-https://gh-proxy.com/https://raw.githubusercontent.com https://ghproxy.imciel.com/https://raw.githubusercontent.com https://gitproxy.mrhjx.cn/https://raw.githubusercontent.com https://gh.jasonzeng.dev/https://raw.githubusercontent.com https://gh.monlor.com/https://raw.githubusercontent.com https://gh.noki.icu/https://raw.githubusercontent.com https://ghfast.top/https://raw.githubusercontent.com https://fastly.jsdelivr.net/gh}"
FETCH_TIMEOUT="${LOCALCLASH_FETCH_TIMEOUT:-20}"
TASK_STEP_TIMEOUT="${LOCALCLASH_TASK_STEP_TIMEOUT:-240}"
TAKEOVER_SKIP_FILE="${LOCALCLASH_TAKEOVER_SKIP_FILE:-/tmp/localclash-skip-takeover}"

json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

ok() {
	printf '{"ok":true,%s}\n' "$1"
}

fail() {
	code="$(json_escape "$1")"
	message="$(json_escape "$2")"
	printf '{"ok":false,"code":"%s","message":"%s","details":{},"next_actions":[]}\n' "$code" "$message"
}

log_line() {
	printf '%s %s\n' "$(date -Iseconds 2>/dev/null || date)" "$*" >> "$LOG"
}

takeover_skip_enabled() {
	[ "${LOCALCLASH_TAKEOVER_SKIP:-0}" = "1" ] || [ -f "$TAKEOVER_SKIP_FILE" ]
}

now_epoch() {
	date +%s 2>/dev/null || printf '0\n'
}

write_task_running() {
	printf '{"ok":true,"running":true,"done":false,"started_at":%s,"summary":"%s"}\n' "$(now_epoch)" "$(json_escape "$1")" > "$TASK_STATUS"
}

write_task_pid() {
	[ -n "$1" ] || return 0
	printf '%s\n' "$1" > "$TASK_PID"
}

task_started_at() {
	jsonfilter -i "$TASK_STATUS" -e '@.started_at' 2>/dev/null || printf '0\n'
}

task_pid_alive() {
	local pid
	[ -f "$TASK_PID" ] || return 1
	pid="$(cat "$TASK_PID" 2>/dev/null)"
	[ -n "$pid" ] || return 1
	kill -0 "$pid" 2>/dev/null
}

lock_pid_alive() {
	local pid
	[ -f "$LOCK_DIR/pid" ] || return 1
	pid="$(cat "$LOCK_DIR/pid" 2>/dev/null)"
	[ -n "$pid" ] || return 1
	kill -0 "$pid" 2>/dev/null
}

clear_stale_lock() {
	[ -d "$LOCK_DIR" ] || return 0
	if ! lock_pid_alive; then
		rm -rf "$LOCK_DIR" 2>/dev/null || true
		log_line "任务锁：已清理失效任务锁"
	fi
}

clear_stale_task_pid() {
	[ -f "$TASK_PID" ] || return 0
	task_pid_alive && return 0
	rm -f "$TASK_PID" 2>/dev/null || true
}

write_task_stale_result() {
	local result
	result='{"ok":false,"code":"task_interrupted","message":"初始化任务已中断，请重试。","details":{},"next_actions":["点击一键初始化重试。"]}'
	printf '%s\n' "$result" > "$TASK_RESULT"
	printf '{"ok":true,"running":false,"done":true,"exit_code":124,"result":%s}\n' "$result" > "$TASK_STATUS"
}

reconcile_task_status() {
	local started age
	[ -f "$TASK_STATUS" ] || return 0
	grep -q '"running":true' "$TASK_STATUS" 2>/dev/null || return 0
	clear_stale_lock
	clear_stale_task_pid
	[ -d "$LOCK_DIR" ] && return 0
	task_pid_alive && return 0
	started="$(task_started_at)"
	age=$(( $(now_epoch) - started ))
	[ "$started" -gt 0 ] && [ "$age" -lt 10 ] && return 0
	if ! ps w 2>/dev/null | grep -q '[l]ocalclash .*_run'; then
		log_line "任务状态：检测到后台任务已中断"
		write_task_stale_result
	fi
}

with_lock() {
	waited=0
	while ! mkdir "$LOCK_DIR" 2>/dev/null; do
		clear_stale_lock
		if [ "$waited" -ge 120 ]; then
			log_line "等待任务锁超时：$*"
			fail "task_locked" "另一个 localClash 任务仍在运行，请稍后再试。"
			return 1
		fi
		waited=$((waited + 1))
		sleep 1
	done
	printf '%s\n' "$$" > "$LOCK_DIR/pid"
	trap 'rm -rf "$LOCK_DIR" 2>/dev/null || true' EXIT INT TERM
	"$@"
	rc=$?
	rm -rf "$LOCK_DIR" 2>/dev/null || true
	trap - EXIT INT TERM
	return "$rc"
}

child_pids() {
	local parent status pid ppid
	parent="$1"
	for status in /proc/[0-9]*/status; do
		[ -r "$status" ] || continue
		pid="$(awk '$1 == "Pid:" { print $2; exit }' "$status" 2>/dev/null)"
		ppid="$(awk '$1 == "PPid:" { print $2; exit }' "$status" 2>/dev/null)"
		[ "$ppid" = "$parent" ] && [ -n "$pid" ] && printf '%s\n' "$pid"
	done
}

kill_process_tree() {
	local signal pid child
	signal="$1"
	pid="$2"
	[ -n "$pid" ] || return 0
	for child in $(child_pids "$pid"); do
		kill_process_tree "$signal" "$child"
	done
	kill "$signal" "$pid" 2>/dev/null || true
}

task_cancel() {
	local pid lock_pid result killed
	killed=0
	reconcile_task_status
	if ! task_pid_alive && ! lock_pid_alive; then
		log_line "任务控制：没有正在运行的任务可中止"
		if [ -f "$TASK_STATUS" ]; then
			cat "$TASK_STATUS"
		else
			fail "task_not_running" "当前没有正在运行的 localClash 任务。"
		fi
		return 0
	fi
	log_line "任务控制：收到中止请求"
	if [ -f "$TASK_PID" ]; then
		pid="$(cat "$TASK_PID" 2>/dev/null)"
		if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
			kill_process_tree -TERM "$pid"
			killed=1
		fi
	fi
	if [ -f "$LOCK_DIR/pid" ]; then
		lock_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null)"
		if [ -n "$lock_pid" ] && [ "$lock_pid" != "$pid" ] && kill -0 "$lock_pid" 2>/dev/null; then
			kill_process_tree -TERM "$lock_pid"
			killed=1
		fi
	fi
	if [ "$killed" -eq 1 ]; then
		sleep 2
		[ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && kill_process_tree -KILL "$pid"
		[ -n "$lock_pid" ] && kill -0 "$lock_pid" 2>/dev/null && kill_process_tree -KILL "$lock_pid"
	fi
	rm -rf "$LOCK_DIR" 2>/dev/null || true
	rm -f "$TASK_PID" "$TASK_INPUT" 2>/dev/null || true
	result='{"ok":false,"code":"task_cancelled","message":"任务已中止。","details":{},"next_actions":["可以重新执行刚才的操作。"]}'
	printf '%s\n' "$result" > "$TASK_RESULT"
	printf '{"ok":true,"running":false,"done":true,"exit_code":130,"result":%s}\n' "$result" > "$TASK_STATUS"
	log_line "任务控制：任务已中止"
	printf '%s\n' "$result"
}

run_with_heartbeat() {
	local label output tmp_output pid elapsed rc
	label="$1"
	output="$2"
	shift 2
	elapsed=0
	tmp_output="${output}.run.$$"
	rm -f "$tmp_output"
	( "$@" > "$tmp_output" ) &
	pid="$!"
	while kill -0 "$pid" 2>/dev/null; do
		sleep 5
		if kill -0 "$pid" 2>/dev/null; then
			elapsed=$((elapsed + 5))
			log_line "$label：仍在执行（${elapsed}s）"
			if [ "$TASK_STEP_TIMEOUT" -gt 0 ] && [ "$elapsed" -ge "$TASK_STEP_TIMEOUT" ]; then
				log_line "$label：超过 ${TASK_STEP_TIMEOUT}s，已停止等待"
				kill_process_tree -TERM "$pid"
				sleep 2
				kill_process_tree -KILL "$pid"
				wait "$pid" 2>/dev/null || true
				rm -f "$tmp_output"
				printf '{"ok":false,"code":"step_timeout","message":"%s 超时，请检查路由器是否能访问下载源，或稍后重试。","details":{"timeout_seconds":%s},"next_actions":["确认路由器可以访问下载源后重试。"]}\n' "$(json_escape "$label")" "$TASK_STEP_TIMEOUT" > "$output"
				return 124
			fi
		fi
	done
	wait "$pid"
	rc="$?"
	if [ -f "$tmp_output" ]; then
		mv "$tmp_output" "$output"
	else
		: > "$output"
	fi
	return "$rc"
}

fetch_single_url() {
	local url output
	url="$1"
	output="$2"
	if command -v uclient-fetch >/dev/null 2>&1; then
		fetch_with_watchdog "$url" uclient-fetch -T "$FETCH_TIMEOUT" -q -O "$output" "$url"
	elif command -v wget >/dev/null 2>&1; then
		fetch_with_watchdog "$url" wget -T "$FETCH_TIMEOUT" -q -O "$output" "$url"
	elif command -v curl >/dev/null 2>&1; then
		fetch_with_watchdog "$url" curl --max-time "$FETCH_TIMEOUT" -fsSL "$url" -o "$output"
	else
		return 1
	fi
}

fetch_with_watchdog() {
	local label pid watchdog elapsed rc
	label="$1"
	shift
	"$@" &
	pid="$!"
	(
		elapsed=0
		while kill -0 "$pid" 2>/dev/null; do
			sleep 5
			if kill -0 "$pid" 2>/dev/null; then
				elapsed=$((elapsed + 5))
				log_line "下载：等待 $label（${elapsed}s）"
				if [ "$elapsed" -ge "$FETCH_TIMEOUT" ]; then
					kill "$pid" 2>/dev/null || exit 0
					sleep 2
					kill -9 "$pid" 2>/dev/null || true
					exit 0
				fi
			fi
		done
	) &
	watchdog="$!"
	wait "$pid"
	rc="$?"
	kill "$watchdog" 2>/dev/null || true
	return "$rc"
}

probe_url_for_mirror() {
	local kind mirror
	kind="$1"
	mirror="$2"
	case "$kind:$mirror" in
		release:*)
			printf '%s/qoli/syncnext-api/main/pass.txt\n' "$(printf '%s' "$mirror" | sed 's#https://github.com#https://raw.githubusercontent.com#')"
			;;
		raw:https://fastly.jsdelivr.net/gh)
			printf 'https://fastly.jsdelivr.net/gh/qoli/syncnext-api@main/pass.txt\n'
			;;
		raw:*)
			printf '%s/qoli/syncnext-api/main/pass.txt\n' "$mirror"
			;;
	esac
}

mirror_probe_ok() {
	local kind mirror probe tmp body
	kind="$1"
	mirror="$2"
	probe="$(probe_url_for_mirror "$kind" "$mirror")"
	tmp="/tmp/localclash-mirror-probe.$$"
	rm -f "$tmp"
	log_line "下载：探测 $kind 镜像 $mirror"
	if ! fetch_single_url "$probe" "$tmp"; then
		rm -f "$tmp"
		return 1
	fi
	body="$(tr -d '\r\n' < "$tmp" 2>/dev/null)"
	rm -f "$tmp"
	[ "$body" = "pass" ]
}

select_github_mirror() {
	local kind mirrors mirror cache
	kind="$1"
	mirrors="$2"
	mkdir -p "$MIRROR_CACHE_DIR"
	cache="$MIRROR_CACHE_DIR/$kind"

	if [ -f "$cache" ]; then
		mirror="$(cat "$cache")"
		if [ -n "$mirror" ]; then
			printf '%s\n' "$mirror"
			return 0
		fi
	fi

	for mirror in $mirrors; do
		if mirror_probe_ok "$kind" "$mirror"; then
			printf '%s\n' "$mirror" > "$cache"
			log_line "下载：已选择 $kind 镜像 $mirror"
			printf '%s\n' "$mirror"
			return 0
		fi
	done

	rm -f "$cache"
	return 1
}

cache_github_mirror() {
	local kind mirror cache current
	kind="$1"
	mirror="$2"
	[ -n "$mirror" ] || return 0
	mkdir -p "$MIRROR_CACHE_DIR"
	cache="$MIRROR_CACHE_DIR/$kind"
	current="$(cat "$cache" 2>/dev/null || true)"
	if [ "$current" != "$mirror" ]; then
		printf '%s\n' "$mirror" > "$cache"
		log_line "下载：已确认 $kind 镜像 $mirror"
	fi
}

invalidate_github_mirror() {
	local kind mirror cache current
	kind="$1"
	mirror="$2"
	[ -n "$mirror" ] || return 0
	cache="$MIRROR_CACHE_DIR/$kind"
	current="$(cat "$cache" 2>/dev/null || true)"
	if [ "$current" = "$mirror" ]; then
		rm -f "$cache"
		log_line "下载：已丢弃 $kind 镜像 $mirror"
	fi
}

github_url_kind() {
	case "$1" in
		https://github.com/*) printf 'release\n' ;;
		https://raw.githubusercontent.com/*) printf 'raw\n' ;;
	esac
}

candidate_mirror_for_kind() {
	local kind candidate mirrors mirror
	kind="$1"
	candidate="$2"
	case "$kind" in
		release) mirrors="$GITHUB_RELEASE_MIRRORS" ;;
		raw) mirrors="$GITHUB_RAW_MIRRORS" ;;
		*) return 1 ;;
	esac
	for mirror in $mirrors; do
		case "$candidate" in
			"$mirror"/*)
				printf '%s\n' "$mirror"
				return 0
				;;
		esac
	done
	return 1
}

note_github_candidate_success() {
	local url candidate kind mirror
	url="$1"
	candidate="$2"
	kind="$(github_url_kind "$url")"
	[ -n "$kind" ] || return 0
	mirror="$(candidate_mirror_for_kind "$kind" "$candidate" || true)"
	cache_github_mirror "$kind" "$mirror"
}

note_github_candidate_failure() {
	local url candidate kind mirror
	url="$1"
	candidate="$2"
	kind="$(github_url_kind "$url")"
	[ -n "$kind" ] || return 0
	mirror="$(candidate_mirror_for_kind "$kind" "$candidate" || true)"
	invalidate_github_mirror "$kind" "$mirror"
}

raw_github_to_jsdelivr() {
	local rest owner repo branch path
	rest="${1#https://raw.githubusercontent.com/}"
	owner="${rest%%/*}"
	rest="${rest#*/}"
	repo="${rest%%/*}"
	rest="${rest#*/}"
	branch="${rest%%/*}"
	path="${rest#*/}"
	if [ -n "$owner" ] && [ -n "$repo" ] && [ -n "$branch" ] && [ -n "$path" ]; then
		printf 'https://fastly.jsdelivr.net/gh/%s/%s@%s/%s\n' "$owner" "$repo" "$branch" "$path"
	fi
}

github_download_candidates() {
	local url mirror selected
	url="$1"
	case "$GITHUB_MIRROR" in
		0|off|false|direct|none)
			printf '%s\n' "$url"
			return 0
			;;
	esac

	case "$url" in
		https://github.com/*)
			selected="$(select_github_mirror release "$GITHUB_RELEASE_MIRRORS" 2>/dev/null || true)"
			if [ -n "$selected" ]; then
				printf '%s%s\n' "$selected" "${url#https://github.com}"
			fi
			for mirror in $GITHUB_RELEASE_MIRRORS; do
				[ "$mirror" = "$selected" ] || printf '%s%s\n' "$mirror" "${url#https://github.com}"
			done
			;;
		https://raw.githubusercontent.com/*)
			selected="$(select_github_mirror raw "$GITHUB_RAW_MIRRORS" 2>/dev/null || true)"
			if [ -n "$selected" ]; then
				case "$selected" in
					https://fastly.jsdelivr.net/gh) raw_github_to_jsdelivr "$url" ;;
					*) printf '%s%s\n' "$selected" "${url#https://raw.githubusercontent.com}" ;;
				esac
			fi
			for mirror in $GITHUB_RAW_MIRRORS; do
				[ "$mirror" = "$selected" ] && continue
				case "$mirror" in
					https://fastly.jsdelivr.net/gh) raw_github_to_jsdelivr "$url" ;;
					*) printf '%s%s\n' "$mirror" "${url#https://raw.githubusercontent.com}" ;;
				esac
			done
			;;
	esac

	printf '%s\n' "$url"
}

fetch_url() {
	local url output tmp candidate
	url="$1"
	output="$2"
	tmp="$output.download.$$"
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			mv "$tmp" "$output"
			note_github_candidate_success "$url" "$candidate"
			return 0
		fi
		note_github_candidate_failure "$url" "$candidate"
		rm -f "$tmp"
	done
	return 1
}

fetch_manifest() {
	local url output tmp candidate
	url="$1"
	output="$2"
	tmp="$output.download.$$"
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			if jsonfilter -i "$tmp" -e '@.version' >/dev/null 2>&1; then
				mv "$tmp" "$output"
				note_github_candidate_success "$url" "$candidate"
				return 0
			fi
			log_line "下载：$candidate 返回的 Release 清单无效"
			note_github_candidate_failure "$url" "$candidate"
		else
			note_github_candidate_failure "$url" "$candidate"
		fi
		rm -f "$tmp"
	done
	return 1
}

fetch_url_verified() {
	local url output expected_sha tmp candidate actual_sha
	url="$1"
	output="$2"
	expected_sha="$3"
	tmp="$output.download.$$"
	rm -f "$tmp"
	for candidate in $(github_download_candidates "$url"); do
		log_line "下载：尝试 $candidate"
		if fetch_single_url "$candidate" "$tmp"; then
			actual_sha="$(sha256sum "$tmp" | cut -d ' ' -f 1)"
			if [ "$actual_sha" = "$expected_sha" ]; then
				mv "$tmp" "$output"
				note_github_candidate_success "$url" "$candidate"
				return 0
			fi
			log_line "下载：$candidate 校验和不匹配"
			note_github_candidate_failure "$url" "$candidate"
		else
			note_github_candidate_failure "$url" "$candidate"
		fi
		rm -f "$tmp"
	done
	return 1
}

router_arch() {
	case "$(uname -m)" in
		aarch64|arm64) echo "arm64" ;;
		x86_64|amd64) echo "amd64" ;;
		*) return 1 ;;
	esac
}

core_installed() {
	[ -x "$CORE" ]
}

validate_state_dir_path() {
	local path
	path="$1"
	case "$path" in
		/*) ;;
		*)
			fail "invalid_state_dir" "localClash 工作目录必须是绝对路径。"
			return 1
			;;
	esac
	case "$path" in
		/|/bin|/dev|/etc|/lib|/lib64|/opt|/proc|/root|/sbin|/sys|/tmp|/usr|/var)
			fail "invalid_state_dir" "localClash 工作目录过于宽泛，拒绝执行。"
			return 1
			;;
	esac
	return 0
}

resolve_state_dir() {
	local workdir
	validate_state_dir_path "$STATE_DIR" || return 1
	mkdir -p "$STATE_DIR" || {
		fail "state_dir_create_failed" "无法创建 localClash 工作目录。"
		return 1
	}
	workdir="$(cd "$STATE_DIR" 2>/dev/null && pwd -P)" || {
		fail "state_dir_resolve_failed" "无法解析 localClash 工作目录。"
		return 1
	}
	validate_state_dir_path "$workdir" || return 1
	printf '%s\n' "$workdir"
}

call_core() {
	local workdir
	if ! core_installed; then
		fail "bootstrap_core_missing" "localClash 核心尚未安装。"
		return 1
	fi
	workdir="$(resolve_state_dir)" || return 1
	(cd / && LOCALCLASH_WORKDIR="$workdir" "$CORE" "$@") 2>>"$LOG"
}

runtime_stop() {
	call_core runtime stop --json
}

runtime_start() {
	call_core runtime start --json
}

runtime_restart() {
	call_core runtime restart --json
}

base_assets_installed() {
	local tmp installed
	core_installed || return 1
	tmp="/tmp/localclash-component-status.$$.json"
	if ! call_core component status --json > "$tmp" 2>/tmp/localclash-component-status.$$.err; then
		rm -f "$tmp" /tmp/localclash-component-status.$$.err
		return 1
	fi
	installed="$(jsonfilter -i "$tmp" -e '@.status.base_assets.installed' 2>/dev/null || true)"
	rm -f "$tmp" /tmp/localclash-component-status.$$.err
	[ "$installed" = "true" ]
}

base_assets_missing_reason() {
	if ! core_installed; then
		printf 'localClash 核心尚未安装。'
		return 0
	fi
	printf '需要由 localClash 核心安装基础文件。'
}

base_assets_body() {
	local installed tmp path missing policy default_template rule_source_dir default_patch_count default_patches_installed
	installed=false
	path="$STATE_DIR"
	missing=""
	policy=""
	default_template=""
	rule_source_dir=""
	default_patch_count=0
	default_patches_installed=false
	if core_installed; then
		tmp="/tmp/localclash-component-status.$$.json"
		if call_core component status --json > "$tmp" 2>/dev/null; then
			installed="$(jsonfilter -i "$tmp" -e '@.status.base_assets.installed' 2>/dev/null || printf false)"
			path="$(jsonfilter -i "$tmp" -e '@.status.base_assets.path' 2>/dev/null || printf '%s' "$STATE_DIR")"
			missing="$(jsonfilter -i "$tmp" -e '@.status.base_assets.missing[*]' 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//')"
			policy="$(jsonfilter -i "$tmp" -e '@.status.base_assets.policy' 2>/dev/null || true)"
			default_template="$(jsonfilter -i "$tmp" -e '@.status.base_assets.default_template' 2>/dev/null || true)"
			rule_source_dir="$(jsonfilter -i "$tmp" -e '@.status.base_assets.rule_source_dir' 2>/dev/null || true)"
			default_patch_count="$(jsonfilter -i "$tmp" -e '@.status.base_assets.default_patch_count' 2>/dev/null || printf 0)"
			default_patches_installed="$(jsonfilter -i "$tmp" -e '@.status.base_assets.default_patches_installed' 2>/dev/null || printf false)"
			if [ "${default_patch_count:-0}" -gt 0 ]; then
				default_template="patch_set"
			fi
		fi
		rm -f "$tmp"
	fi
	printf '"base_assets":{"installed":%s,"path":"%s","source":"localclash-core","missing":"%s","policy":"%s","default_template":"%s","rule_source_dir":"%s","default_patch_count":%s,"default_patches_installed":%s}' "$installed" "$(json_escape "$path")" "$(json_escape "$missing")" "$(json_escape "$policy")" "$(json_escape "$default_template")" "$(json_escape "$rule_source_dir")" "${default_patch_count:-0}" "$default_patches_installed"
}

