#!/bin/sh

CORE="${LOCALCLASH_CORE:-/usr/local/bin/localclash}"
SERVICE="/etc/init.d/localclash-mcp"
LOG="/tmp/localclash-helper.log"
MCP_ADDR="${LOCALCLASH_MCP_ADDR:-0.0.0.0:8765}"
MCP_HELP="/usr/share/localclash/mcp-help.txt"
MANIFEST_URL="${LOCALCLASH_RELEASE_MANIFEST:-https://github.com/qoli/localClash/releases/latest/download/localclash-release-manifest.json}"

json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

ok() {
	printf '{"ok":true,%s}\n' "$1"
}

fail() {
	code="$(json_escape "$1")"
	message="$(json_escape "$2")"
	printf '{"ok":false,"code":"%s","message":"%s","details":{},"next_actions":[]}\n' "$code" "$message"
}

log_line() {
	printf '%s %s\n' "$(date -Iseconds 2>/dev/null || date)" "$*" >> "$LOG"
}

fetch_url() {
	url="$1"
	output="$2"
	if command -v uclient-fetch >/dev/null 2>&1; then
		uclient-fetch -q -O "$output" "$url"
	elif command -v wget >/dev/null 2>&1; then
		wget -q -O "$output" "$url"
	elif command -v curl >/dev/null 2>&1; then
		curl -fsSL "$url" -o "$output"
	else
		return 1
	fi
}

router_arch() {
	case "$(uname -m)" in
		aarch64|arm64) echo "arm64" ;;
		x86_64|amd64) echo "amd64" ;;
		*) return 1 ;;
	esac
}

core_installed() {
	[ -x "$CORE" ]
}

call_core() {
	if ! core_installed; then
		fail "bootstrap_core_missing" "localClash core is not installed."
		return 1
	fi
	"$CORE" "$@"
}

service_body() {
	installed=false
	enabled=false
	running=false
	pid=0
	if [ -x "$SERVICE" ]; then
		installed=true
		"$SERVICE" enabled >/dev/null 2>&1 && enabled=true
		if "$SERVICE" running >/dev/null 2>&1; then
			running=true
		fi
	fi
	endpoint="$(mcp_endpoint)"
	health_endpoint="${endpoint%/mcp}/health"
	printf '"service":{"name":"localclash-mcp","installed":%s,"enabled":%s,"running":%s,"pid":%s},"mcp":{"endpoint":"%s","health_endpoint":"%s","healthy":false,"last_error":""}' "$installed" "$enabled" "$running" "$pid" "$(json_escape "$endpoint")" "$(json_escape "$health_endpoint")"
}

mcp_host() {
	host="${MCP_ADDR%:*}"
	if [ "$host" != "0.0.0.0" ] && [ "$host" != "::" ] && [ -n "$host" ]; then
		printf '%s\n' "$host"
		return 0
	fi
	if command -v uci >/dev/null 2>&1; then
		lan_ip="$(uci -q get network.lan.ipaddr 2>/dev/null || true)"
		if [ -n "$lan_ip" ]; then
			printf '%s\n' "$lan_ip"
			return 0
		fi
	fi
	if command -v ip >/dev/null 2>&1; then
		lan_ip="$(ip -4 addr show br-lan 2>/dev/null | sed -n 's/.*inet \([0-9.]*\)\/.*/\1/p' | head -n 1)"
		if [ -n "$lan_ip" ]; then
			printf '%s\n' "$lan_ip"
			return 0
		fi
	fi
	printf '192.168.1.1\n'
}

mcp_endpoint() {
	port="${MCP_ADDR##*:}"
	printf 'http://%s:%s/mcp\n' "$(mcp_host)" "$port"
}

service_status() {
	ok "$(service_body)"
}

mcp_help() {
	endpoint="$(mcp_endpoint)"
	if [ -f "$MCP_HELP" ]; then
		text="$(sed "s#http://192\\.168\\.6\\.1:8765/mcp#$endpoint#g" "$MCP_HELP")"
	else
		text="Please connect to localClash MCP at $endpoint, first call tools_list and environment_inspect, then use the reported safety_level before making any runtime or router takeover changes."
	fi
	ok "\"text\":\"$(json_escape "$text")\",\"endpoint\":\"$(json_escape "$endpoint")\""
}

service_ensure() {
	mkdir -p "$(dirname "$SERVICE")"
	cat > "$SERVICE" <<EOF
#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

CORE="$CORE"
MCP_ADDR="$MCP_ADDR"

start_service() {
	if [ ! -x "\$CORE" ]; then
		echo "localClash core missing: \$CORE" >&2
		return 1
	fi
	procd_open_instance
	procd_set_param command "\$CORE" mcp serve --addr "\$MCP_ADDR" --path /mcp
	procd_set_param respawn
	procd_close_instance
}
EOF
	chmod 755 "$SERVICE"
	log_line "service ensured at $SERVICE"
	ok '"changed":true,"summary":"MCP service wrapper ensured."'
}

status() {
	core_json='{"ok":false,"code":"bootstrap_core_missing","message":"localClash core is not installed.","details":{},"next_actions":["Install localClash core."]}'
	if core_installed; then
		core_json="$("$CORE" status --json 2>/dev/null)" || core_json='{"ok":false,"code":"core_status_failed","message":"localClash core status failed.","details":{},"next_actions":[]}'
	fi
	printf '{"ok":true,"core":{"installed":%s,"path":"%s"},"mcp_service":{%s},"status":%s}\n' "$(core_installed && echo true || echo false)" "$CORE" "$(service_body)" "$core_json"
}

component_update() {
	payload="$(cat)"
	component="$(jsonfilter -s "$payload" -e '@.component' 2>/dev/null)"
	case "$component" in
		localclash) bootstrap_core ;;
		mihomo|dashboard) call_core component update "$component" --json ;;
		*) fail "invalid_component" "component must be localclash, mihomo, or dashboard." ;;
	esac
}

input_to_core_file() {
	payload="$(cat)"
	tmp="/tmp/localclash-input-$$.json"
	printf '%s' "$payload" > "$tmp"
	call_core "$@" --input "$tmp" --json
	rc=$?
	rm -f "$tmp"
	return "$rc"
}

subscription_set() {
	input_to_core_file subscription set
}

apply_state() {
	input_to_core_file apply
}

bootstrap_core() {
	if ! command -v jsonfilter >/dev/null 2>&1; then
		fail "jsonfilter_missing" "jsonfilter is required to parse the localClash release manifest."
		return 1
	fi
	arch="$(router_arch)" || {
		fail "unsupported_arch" "This router architecture is not supported by the localClash bootstrap helper."
		return 1
	}
	tmpdir="$(mktemp -d /tmp/localclash-bootstrap.XXXXXX)" || {
		fail "tmpdir_failed" "Could not create a temporary bootstrap directory."
		return 1
	}
	manifest="$tmpdir/manifest.json"
	binary="$tmpdir/localclash"
	if ! fetch_url "$MANIFEST_URL" "$manifest"; then
		rm -rf "$tmpdir"
		fail "manifest_download_failed" "Could not download localClash release manifest."
		return 1
	fi
	asset_url="$(jsonfilter -i "$manifest" -e "@.assets[@.arch=\"$arch\"].url" 2>/dev/null)"
	asset_sha="$(jsonfilter -i "$manifest" -e "@.assets[@.arch=\"$arch\"].sha256" 2>/dev/null)"
	asset_version="$(jsonfilter -i "$manifest" -e "@.version" 2>/dev/null)"
	if [ -z "$asset_url" ] || [ -z "$asset_sha" ]; then
		rm -rf "$tmpdir"
		fail "manifest_asset_missing" "Release manifest does not contain a matching linux binary for this router."
		return 1
	fi
	if ! fetch_url "$asset_url" "$binary"; then
		rm -rf "$tmpdir"
		fail "core_download_failed" "Could not download localClash core binary."
		return 1
	fi
	actual_sha="$(sha256sum "$binary" | cut -d ' ' -f 1)"
	if [ "$actual_sha" != "$asset_sha" ]; then
		rm -rf "$tmpdir"
		fail "checksum_mismatch" "Downloaded localClash core failed sha256 verification."
		return 1
	fi
	chmod 755 "$binary"
	mkdir -p "$(dirname "$CORE")"
	tmp_core="$CORE.tmp.$$"
	if ! cp "$binary" "$tmp_core" || ! chmod 755 "$tmp_core" || ! mv "$tmp_core" "$CORE"; then
		rm -f "$tmp_core"
		rm -rf "$tmpdir"
		fail "core_install_failed" "Could not install localClash core binary."
		return 1
	fi
	rm -rf "$tmpdir"
	service_ensure >/dev/null
	log_line "installed localClash core $asset_version for $arch"
	ok "\"changed\":true,\"summary\":\"localClash core installed.\",\"core\":{\"installed\":true,\"path\":\"$CORE\",\"version\":\"$(json_escape "$asset_version")\",\"arch\":\"$arch\"}"
}

bootstrap_logs() {
	if [ -f "$LOG" ]; then
		tail -n 80 "$LOG" | sed 's/"/\\"/g' | awk 'BEGIN{printf "{\"ok\":true,\"logs\":["} {printf "%s\"%s\"", sep, $0; sep=","} END{print "]}" }'
	else
		printf '{"ok":true,"logs":[]}\n'
	fi
}

bootstrap_default() {
	tmpdir="$(mktemp -d /tmp/localclash-default.XXXXXX)" || {
		fail "tmpdir_failed" "Could not create a temporary default setup directory."
		return 1
	}

	if ! core_installed; then
		if ! bootstrap_core > "$tmpdir/core.json"; then
			cat "$tmpdir/core.json"
			rm -rf "$tmpdir"
			return 1
		fi
	else
		printf '{"ok":true,"changed":false,"summary":"localClash core already installed."}\n' > "$tmpdir/core.json"
	fi

	if ! call_core component update mihomo --json > "$tmpdir/mihomo.json"; then
		cat "$tmpdir/mihomo.json"
		rm -rf "$tmpdir"
		return 1
	fi

	if ! call_core component update dashboard --json > "$tmpdir/dashboard.json"; then
		cat "$tmpdir/dashboard.json"
		rm -rf "$tmpdir"
		return 1
	fi

	cat > "$tmpdir/apply.json" <<'JSON'
{
  "components": {
    "mihomo": "installed_or_latest",
    "dashboard": "installed_or_latest"
  },
  "config": {
    "template": "localclash-default",
    "runtime_profile": "router",
    "core": "smart",
    "allow_overwrite_modified": false
  },
  "runtime": {
    "service": "leave",
    "router_takeover": "leave"
  }
}
JSON

	if ! call_core apply --input "$tmpdir/apply.json" --json > "$tmpdir/apply-result.json"; then
		cat "$tmpdir/apply-result.json"
		rm -rf "$tmpdir"
		return 1
	fi

	service_ensure >/dev/null
	rm -rf "$tmpdir"
	ok '"changed":true,"summary":"Default router setup applied.","profile":{"runtime_profile":"router","core":"smart","template":"localclash-default"}'
}

method="${1:-}"
if [ "$method" = "call" ]; then
	method="${2:-}"
fi

case "$method" in
	list)
		cat <<'JSON'
{
  "status": {},
  "subscription_set": { "urls": [] },
  "subscription_refresh": {},
  "component_update": { "component": "localclash" },
  "apply": {},
  "runtime_start": {},
  "runtime_restart": {},
  "runtime_stop": {},
  "takeover_status": {},
  "takeover_apply": {},
  "takeover_stop": {},
  "reset": {},
  "service_start": {},
  "service_stop": {},
  "service_status": {},
  "service_ensure": {},
  "bootstrap_core": {},
  "bootstrap_default": {},
  "mcp_help": {},
  "bootstrap_logs": {}
}
JSON
		;;
	status) status ;;
	subscription_set) subscription_set ;;
	subscription_refresh) call_core subscription refresh --json ;;
	component_update) component_update ;;
	apply) apply_state ;;
	runtime_start) call_core runtime start --json ;;
	runtime_restart) call_core runtime restart --json ;;
	runtime_stop) call_core runtime stop --json ;;
	takeover_status) call_core takeover status --json ;;
	takeover_apply) call_core takeover apply --json ;;
	takeover_stop) call_core takeover stop --json ;;
	reset) call_core reset --json ;;
	service_status) service_status ;;
	service_ensure) service_ensure ;;
	service_start) service_ensure >/dev/null && "$SERVICE" start >/dev/null 2>&1 && service_status || fail "service_start_failed" "Could not start localclash-mcp service." ;;
	service_stop) [ -x "$SERVICE" ] && "$SERVICE" stop >/dev/null 2>&1; service_status ;;
	bootstrap_core) bootstrap_core ;;
	bootstrap_default) bootstrap_default ;;
	mcp_help) mcp_help ;;
	bootstrap_logs) bootstrap_logs ;;
	*) fail "unknown_method" "Unknown localClash rpcd method." ;;
esac
