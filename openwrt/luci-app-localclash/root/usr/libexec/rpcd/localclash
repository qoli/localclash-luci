bootstrap_core() {
	local arch tmpdir manifest binary asset_url asset_sha asset_version tmp_core
	log_line "核心初始化：开始"
	if ! command -v jsonfilter >/dev/null 2>&1; then
		log_line "核心初始化：缺少 jsonfilter"
		fail "jsonfilter_missing" "需要 jsonfilter 解析 localClash Release 清单。"
		return 1
	fi
	arch="$(router_arch)" || {
		log_line "核心初始化：不支持的架构 $(uname -m)"
		fail "unsupported_arch" "localClash 初始化助手不支持此路由器架构。"
		return 1
	}
	tmpdir="$(mktemp -d /tmp/localclash-bootstrap.XXXXXX)" || {
		fail "tmpdir_failed" "无法创建临时初始化目录。"
		return 1
	}
	manifest="$tmpdir/manifest.json"
	binary="$tmpdir/localclash"
	log_line "核心初始化：正在下载 Release 清单"
	if ! fetch_manifest "$MANIFEST_URL" "$manifest"; then
		rm -rf "$tmpdir"
		log_line "核心初始化：Release 清单下载失败"
		fail "manifest_download_failed" "无法下载 localClash Release 清单。"
		return 1
	fi
	asset_url="$(jsonfilter -i "$manifest" -e "@.assets[@.arch=\"$arch\"].url" 2>/dev/null)"
	asset_sha="$(jsonfilter -i "$manifest" -e "@.assets[@.arch=\"$arch\"].sha256" 2>/dev/null)"
	asset_version="$(jsonfilter -i "$manifest" -e "@.version" 2>/dev/null)"
	if [ -z "$asset_url" ] || [ -z "$asset_sha" ]; then
		rm -rf "$tmpdir"
		log_line "核心初始化：Release 清单中没有 $arch 可用文件"
		fail "manifest_asset_missing" "Release 清单中没有匹配此路由器的 Linux 二进制文件。"
		return 1
	fi
	log_line "核心初始化：正在下载 localClash 核心 $asset_version（$arch）"
	if ! fetch_url_verified "$asset_url" "$binary" "$asset_sha"; then
		rm -rf "$tmpdir"
		log_line "核心初始化：核心下载失败"
		fail "core_download_failed" "无法下载 localClash 核心二进制文件。"
		return 1
	fi
	log_line "核心初始化：sha256 校验通过"
	chmod 755 "$binary"
	mkdir -p "$(dirname "$CORE")"
	tmp_core="$CORE.tmp.$$"
	log_line "核心初始化：正在安装 localClash 核心"
	if ! cp "$binary" "$tmp_core" || ! chmod 755 "$tmp_core" || ! mv "$tmp_core" "$CORE"; then
		rm -f "$tmp_core"
		rm -rf "$tmpdir"
		log_line "核心初始化：核心安装失败"
		fail "core_install_failed" "无法安装 localClash 核心二进制文件。"
		return 1
	fi
	if ! install_base_assets "$manifest" "$tmpdir"; then
		rm -rf "$tmpdir"
		return 1
	fi
	rm -rf "$tmpdir"
	if ! service_start >/dev/null; then
		rm -rf "$tmpdir"
		log_line "核心初始化：MCP 服务启动失败"
		fail "service_start_failed" "localClash 核心已安装，但 MCP 服务无法启动。"
		return 1
	fi
	log_line "已安装 localClash 核心 $asset_version（$arch）"
	ok "\"changed\":true,\"summary\":\"localClash 核心已安装。\",\"core\":{\"installed\":true,\"path\":\"$CORE\",\"version\":\"$(json_escape "$asset_version")\",\"arch\":\"$arch\"}"
}

install_base_assets() {
	local output
	output="/tmp/localclash-base-assets.$$.json"
	if ! core_installed; then
		fail "bootstrap_core_missing" "localClash 核心尚未安装，无法初始化基础文件。"
		return 1
	fi
	mkdir -p "$STATE_DIR"
	log_line "基础文件初始化：交由 localClash 核心安装基础文件"
	if ! call_core component update assets --json > "$output"; then
		log_line "基础文件初始化：核心安装基础文件失败"
		cat "$output"
		rm -f "$output"
		return 1
	fi
	log_line "基础文件初始化：已由 localClash 核心安装"
	rm -f "$output"
	return 0
}

bootstrap_assets() {
	log_line "基础文件初始化：开始"
	if ! install_base_assets "" ""; then
		return 1
	fi
	ok "\"changed\":true,\"summary\":\"localClash 基础文件已安装。\",\"base_assets\":{\"installed\":true,\"path\":\"$(json_escape "$STATE_DIR")\"}"
}

bootstrap_logs() {
	if [ -f "$LOG" ]; then
		tail -n 80 "$LOG" | sed 's/"/\\"/g' | awk 'BEGIN{printf "{\"ok\":true,\"logs\":["} {printf "%s\"%s\"", sep, $0; sep=","} END{print "]}" }'
	else
		printf '{"ok":true,"logs":[]}\n'
	fi
}

bootstrap_task_status() {
	reconcile_task_status
	if [ -f "$TASK_STATUS" ]; then
		cat "$TASK_STATUS"
	else
		printf '{"ok":true,"running":false,"done":false,"result":null}\n'
	fi
}

task_status() {
	bootstrap_task_status
}

start_bootstrap_default() {
	local payload result rc bg_pid
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	payload="$(strip_ubus_rpc_session "$(cat)")"
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT" "$TASK_PID"
	: > "$LOG"
	write_versioned_payload "$payload" > "$TASK_INPUT"
	write_task_running "初始化和运行时启动任务正在运行。"
	log_line "默认初始化：已加入后台任务队列"
	(
		result="$("$0" call bootstrap_default_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"初始化任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		printf '{"ok":true,"running":false,"done":true,"exit_code":%s,"result":%s}\n' "$rc" "$result" > "$TASK_STATUS"
		rm -f "$TASK_INPUT" "$TASK_PID"
	) >/dev/null 2>&1 &
	bg_pid="$!"
	write_task_pid "$bg_pid"
	ok '"started":true,"running":true,"summary":"初始化和运行时启动任务已启动。"'
}

bootstrap_default_run() {
	local tmpdir mihomo_attempt payload selected_core selected_template subscription_input subscription_changed subscription_ready runtime_started runtime_result
	payload='{"version":1}'
	selected_core="meta"
	selected_template="localclash-default"
	subscription_changed=false
	subscription_ready=false
	runtime_started=false

	if [ -f "$TASK_INPUT" ]; then
		payload="$(cat "$TASK_INPUT" 2>/dev/null || printf '{"version":1}')"
	fi
	selected_core="$(jsonfilter -s "$payload" -e '@.core' 2>/dev/null || true)"
	selected_template="$(jsonfilter -s "$payload" -e '@.template' 2>/dev/null || true)"
	[ -n "$selected_core" ] || selected_core="meta"
	[ -n "$selected_template" ] || selected_template="localclash-default"
	case "$selected_core" in
		meta|smart) ;;
		*)
			fail "invalid_bootstrap_core" "初始化核心类型必须是 meta 或 smart。"
			return 1
			;;
	esac
	case "$selected_template" in
		minimal|localclash-default) ;;
		*)
			fail "invalid_bootstrap_template" "初始化配置模板必须是 minimal 或 localclash-default。"
			return 1
			;;
	esac

	log_line "默认初始化：开始路由器默认设置"
	tmpdir="$(mktemp -d /tmp/localclash-default.XXXXXX)" || {
		log_line "默认初始化：临时目录创建失败"
		fail "tmpdir_failed" "无法创建临时默认设置目录。"
		return 1
	}

	log_line "默认初始化：第一步更新 localClash 核心"
	if ! bootstrap_core > "$tmpdir/core.json"; then
		cat "$tmpdir/core.json"
		rm -rf "$tmpdir"
		return 1
	fi

	if ! base_assets_installed; then
		log_line "默认初始化：基础文件缺失，开始初始化：$(base_assets_missing_reason)"
		if ! bootstrap_assets > "$tmpdir/assets.json"; then
			cat "$tmpdir/assets.json"
			rm -rf "$tmpdir"
			return 1
		fi
	else
		log_line "默认初始化：基础文件已安装"
	fi

	subscription_input="$tmpdir/subscription.json"
	if write_bootstrap_subscription_input "$payload" "$subscription_input"; then
		log_line "默认初始化：正在保存并刷新订阅"
		if ! subscription_save_refresh_file "$subscription_input" "$tmpdir"; then
			rm -rf "$tmpdir"
			return 1
		fi
		subscription_changed=true
	else
		rm -f "$subscription_input"
		log_line "默认初始化：未收到新的订阅输入"
	fi

	if mihomo_core_installed; then
		log_line "默认初始化：Mihomo 核心已安装，跳过更新"
	else
		log_line "默认初始化：正在更新 Mihomo 核心"
		mihomo_attempt=1
		while ! run_with_heartbeat "默认初始化：正在更新 Mihomo 核心" "$tmpdir/mihomo.json" call_core component update mihomo --json; do
			if [ "$mihomo_attempt" -ge 3 ]; then
				log_line "默认初始化：Mihomo 核心更新失败，已尝试 $mihomo_attempt 次"
				cat "$tmpdir/mihomo.json"
				rm -rf "$tmpdir"
				return 1
			fi
			mihomo_attempt=$((mihomo_attempt + 1))
			log_line "默认初始化：Mihomo 核心更新失败，正在进行第 $mihomo_attempt 次重试"
			sleep 2
		done
	fi

	if dashboard_installed; then
		log_line "默认初始化：Dashboard 面板文件已安装，跳过更新"
	else
		log_line "默认初始化：正在更新 Dashboard 面板文件"
		if ! run_with_heartbeat "默认初始化：正在更新 Dashboard 面板文件" "$tmpdir/dashboard.json" call_core component update dashboard --json; then
			log_line "默认初始化：Dashboard 面板更新失败"
			cat "$tmpdir/dashboard.json"
			rm -rf "$tmpdir"
			return 1
		fi
	fi

	cat > "$tmpdir/template.json" <<JSON
{
  "version": 1,
  "template": "$selected_template",
  "runtime_profile": "router",
  "core": "$selected_core",
  "allow_overwrite_modified": false
}
JSON

	log_line "默认初始化：正在应用 router/$selected_core/$selected_template 默认配置"
	if ! call_core config apply-template --input "$tmpdir/template.json" --json > "$tmpdir/template-result.json"; then
		log_line "默认初始化：默认配置应用失败"
		cat "$tmpdir/template-result.json"
		rm -rf "$tmpdir"
		return 1
	fi

	if [ "$subscription_changed" = true ] || subscription_configured; then
		subscription_ready=true
		log_line "默认初始化：正在生成 Mihomo 配置"
		if ! run_with_heartbeat "默认初始化：正在生成 Mihomo 配置" "$tmpdir/render.json" call_core config render --json; then
			log_line "默认初始化：配置生成失败"
			cat "$tmpdir/render.json"
			rm -rf "$tmpdir"
			return 1
		fi
	else
		log_line "默认初始化：订阅尚未配置，跳过配置生成"
	fi

	if ! service_start >/dev/null; then
		rm -rf "$tmpdir"
		log_line "默认初始化：MCP 服务启动失败"
		fail "service_start_failed" "默认配置已应用，但 MCP 服务无法启动。"
		return 1
	fi

	if [ "$subscription_ready" = true ]; then
		log_line "默认初始化：正在启动运行时并应用网络接管"
		if ! runtime_start_takeover_run > "$tmpdir/runtime-start.json"; then
			log_line "默认初始化：运行时启动和网络接管失败"
			cat "$tmpdir/runtime-start.json"
			rm -rf "$tmpdir"
			return 1
		fi
		runtime_started=true
		runtime_result="$(cat "$tmpdir/runtime-start.json")"
	fi

	rm -rf "$tmpdir"
	log_line "默认初始化：已完成路由器默认设置"
	if [ "$runtime_started" = true ]; then
		printf '{"ok":true,"changed":true,"summary":"已应用路由器默认设置，运行时已启动。","subscription_changed":%s,"profile":{"runtime_profile":"router","core":"%s","template":"%s"},"runtime_start":%s}\n' "$subscription_changed" "$selected_core" "$selected_template" "$runtime_result"
	else
		ok '"changed":true,"summary":"已应用路由器默认设置。","subscription_changed":'"$subscription_changed"',"profile":{"runtime_profile":"router","core":"'"$selected_core"'","template":"'"$selected_template"'"}'
	fi
}

start_runtime_takeover() {
	local result rc bg_pid
	clear_stale_lock
	if [ -d "$LOCK_DIR" ]; then
		printf '{"ok":true,"started":false,"running":true,"summary":"另一个 localClash 任务正在运行。"}\n'
		return 0
	fi
	rm -f "$TASK_STATUS" "$TASK_RESULT" "$TASK_INPUT" "$TASK_PID"
	: > "$LOG"
	write_task_running "运行时启动和网络接管任务正在运行。"
	log_line "运行时接管：已加入后台任务队列"
	(
		result="$("$0" call runtime_start_takeover_run 2>>"$LOG")"
		rc=$?
		if [ -z "$result" ]; then
			result='{"ok":false,"code":"empty_task_result","message":"运行时启动和网络接管任务没有产生 JSON 结果。","details":{},"next_actions":[]}'
		fi
		printf '%s\n' "$result" > "$TASK_RESULT"
		printf '{"ok":true,"running":false,"done":true,"exit_code":%s,"result":%s}\n' "$rc" "$result" > "$TASK_STATUS"
		rm -f "$TASK_PID"
	) >/dev/null 2>&1 &
	bg_pid="$!"
	write_task_pid "$bg_pid"
	ok '"started":true,"running":true,"summary":"运行时启动和网络接管任务已启动。"'
}

runtime_start_takeover_run() {
	local tmpdir
	log_line "运行时接管：开始"
	tmpdir="$(mktemp -d /tmp/localclash-runtime.XXXXXX)" || {
		log_line "运行时接管：临时目录创建失败"
		fail "tmpdir_failed" "无法创建临时 runtime 任务目录。"
		return 1
	}

	log_line "运行时接管：正在启动运行时"
	if ! run_with_heartbeat "运行时接管：正在启动运行时" "$tmpdir/runtime.json" call_core runtime start --json; then
		log_line "运行时接管：运行时启动失败"
		cat "$tmpdir/runtime.json"
		rm -rf "$tmpdir"
		return 1
	fi
	sleep 2
	if ! runtime_running; then
		log_line "运行时接管：运行时启动命令已返回成功，但进程没有保持运行"
		fail "runtime_not_running_after_start" "运行时启动命令已返回，但进程没有保持运行。请查看运行日志；常见原因是端口被 OpenClash 或其他服务占用。"
		rm -rf "$tmpdir"
		return 1
	fi

	if takeover_skip_enabled; then
		log_line "运行时接管：测试模式已启用，跳过网络接管"
		printf '{"ok":true,"changed":true,"summary":"运行时已启动；测试模式已跳过网络接管。","runtime":%s,"takeover":{"ok":true,"changed":false,"skipped":true,"summary":"测试模式已跳过网络接管。"}}\n' "$(cat "$tmpdir/runtime.json")"
		rm -rf "$tmpdir"
		return 0
	fi

	log_line "运行时接管：正在应用网络接管"
	if ! run_with_heartbeat "运行时接管：正在应用网络接管" "$tmpdir/takeover.json" call_core takeover apply --json; then
		log_line "运行时接管：网络接管应用失败"
		log_line "运行时接管：正在撤销可能残留的网络接管"
		if call_core takeover stop --json > "$tmpdir/takeover-stop.json"; then
			log_line "运行时接管：网络接管撤销完成"
		else
			log_line "运行时接管：网络接管撤销也失败"
		fi
		log_line "运行时接管：网络接管失败后正在停止运行时"
		runtime_stop > "$tmpdir/runtime-stop.json" 2>/dev/null || log_line "运行时接管：失败后停止运行时也失败"
		cat "$tmpdir/takeover.json"
		rm -rf "$tmpdir"
		return 1
	fi

	log_line "运行时接管：已完成"
	printf '{"ok":true,"changed":true,"summary":"运行时已启动，网络接管已应用。","runtime":%s,"takeover":%s}\n' "$(cat "$tmpdir/runtime.json")" "$(cat "$tmpdir/takeover.json")"
	rm -rf "$tmpdir"
}

takeover_apply() {
	if takeover_skip_enabled; then
		fail "takeover_skipped_for_test" "测试模式已启用，已阻止网络接管。删除 /tmp/localclash-skip-takeover 后才允许应用网络接管。"
		return 1
	fi

	call_core takeover apply --json
}

method="${1:-}"
if [ "$method" = "call" ]; then
	method="${2:-}"
fi

case "$method" in
	list)
		cat <<'JSON'
{
	  "status": {},
	  "subscription_get": {},
	  "subscription_set": { "urls": [] },
  "subscription_setup": { "urls": [] },
  "subscription_setup_async": { "urls": [] },
  "subscription_refresh": {},
  "component_update": { "component": "localclash" },
  "component_update_async": { "component": "localclash" },
  "apply": {},
  "config_render": {},
  "config_reset": {},
  "runtime_start": {},
  "runtime_start_takeover": {},
  "runtime_restart": {},
  "runtime_stop": {},
  "takeover_status": {},
  "takeover_apply": {},
  "takeover_stop": {},
  "reset": {},
  "service_start": {},
  "service_stop": {},
  "service_status": {},
  "service_ensure": {},
  "bootstrap_core": {},
  "bootstrap_core_async": {},
  "bootstrap_assets": {},
  "bootstrap_default": { "urls": [], "core": "meta", "template": "localclash-default" },
  "task_status": {},
  "task_cancel": {},
  "bootstrap_task_status": {},
  "mcp_help": {},
  "bootstrap_logs": {}
}
JSON
		;;
	status) status ;;
	subscription_get) subscription_get ;;
	subscription_set) subscription_set ;;
	subscription_setup) with_lock subscription_setup ;;
	subscription_setup_async) start_subscription_setup ;;
	subscription_setup_run) with_lock subscription_setup_run ;;
	subscription_refresh) with_lock call_core subscription refresh --json ;;
	component_update) with_lock component_update ;;
	component_update_async) start_component_update ;;
	component_update_run) component_update_run ;;
	apply) with_lock apply_state ;;
	config_render) with_lock config_render ;;
	config_reset) with_lock config_reset ;;
	runtime_start) runtime_start ;;
	runtime_start_takeover) start_runtime_takeover ;;
	runtime_start_takeover_run) with_lock runtime_start_takeover_run ;;
	runtime_restart) runtime_restart ;;
	runtime_stop) runtime_stop ;;
	takeover_status) call_core takeover status --json ;;
	takeover_apply) takeover_apply ;;
	takeover_stop) call_core takeover stop --json ;;
	reset) with_lock reset ;;
	service_status) service_status ;;
	service_ensure) service_ensure ;;
	service_start) service_start ;;
	service_stop) [ -x "$SERVICE" ] && "$SERVICE" stop >/dev/null 2>&1 && "$SERVICE" disable >/dev/null 2>&1; service_status ;;
	bootstrap_core) with_lock bootstrap_core ;;
	bootstrap_core_async) start_bootstrap_core ;;
	bootstrap_core_run) with_lock bootstrap_core ;;
	bootstrap_assets) with_lock bootstrap_assets ;;
	bootstrap_default) start_bootstrap_default ;;
	bootstrap_default_run) with_lock bootstrap_default_run ;;
	task_status) task_status ;;
	task_cancel) task_cancel ;;
	bootstrap_task_status) bootstrap_task_status ;;
	mcp_help) mcp_help ;;
	bootstrap_logs) bootstrap_logs ;;
	*) fail "unknown_method" "未知的 localClash rpcd 方法。" ;;
esac

exit 0
