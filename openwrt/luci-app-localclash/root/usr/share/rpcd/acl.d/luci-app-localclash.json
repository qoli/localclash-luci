{
  "luci-app-localclash": {
    "description": "Grant LuCI access to localClash rpcd helper methods",
    "read": {
      "ubus": {
        "localclash": [ "status", "subscription_get", "service_status", "bootstrap_logs", "task_status", "bootstrap_task_status", "boot_restore_status", "takeover_status", "mcp_help" ]
      }
    },
    "write": {
      "ubus": {
        "localclash": [
          "subscription_set",
          "subscription_setup",
          "subscription_setup_async",
          "subscription_refresh",
          "component_update",
          "component_update_async",
          "apply",
          "config_render",
          "config_reset",
          "runtime_start",
          "runtime_start_takeover",
          "runtime_restart",
          "runtime_stop",
          "boot_restore_enable",
          "boot_restore_disable",
          "boot_restore_run",
          "takeover_apply",
          "takeover_restore",
          "takeover_stop",
          "reset",
          "service_start",
          "service_stop",
          "service_ensure",
          "bootstrap_core",
          "bootstrap_core_async",
          "bootstrap_assets",
          "bootstrap_default",
          "task_cancel"
        ]
      }
    }
  }
}
